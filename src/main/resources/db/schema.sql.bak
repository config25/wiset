    REGISTER               VARCHAR(20)   NOT NULL             COMMENT '등록자',
    UPDDE                  DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                 VARCHAR(20)   NOT NULL             COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN, BIZRNO, STACNT_YEAR),
    CONSTRAINT fk_wrk_reqinst_mngmts_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관경영현황';

