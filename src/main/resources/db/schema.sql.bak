) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='멘토링인터뷰항목';

-- 14세미만 보호자
CREATE TABLE IF NOT EXISTS TN_INDVDL_PRTCTOR (
    USER_SN         BIGINT      NOT NULL              COMMENT '사용자 순번',
    PRTCTOR_NM      VARCHAR(50)                       COMMENT '보호자 명',
    PRTCTOR_SEXDSTN VARCHAR(1)                        COMMENT '보호자 성별',
    PRTCTOR_NLTY    VARCHAR(1)                        COMMENT '보호자 국적',
    PRTCTOR_BRTHDY  VARCHAR(10)                       COMMENT '보호자 생년월일',
