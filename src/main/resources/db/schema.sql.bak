    OFCPS_NM          VARCHAR(100)                       COMMENT '직위명',
    CAREER_SE_CODE    VARCHAR(5)                         COMMENT '경력구분코드',
    PRTCPNT_SE_CODE   VARCHAR(5)                         COMMENT '참여자구분코드',
    PRTCPNT_SE_ETC_NM VARCHAR(100)                       COMMENT '참여자구분기타명',
