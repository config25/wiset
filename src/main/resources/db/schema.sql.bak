    WORK_END_DE          DATETIME                           COMMENT '근무종료일자',
    BSNS_RCVFVR_MONTH_CO INT                                COMMENT '사업수혜개월수',
    RGSDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER             VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR               VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN, USER_SN),
    CONSTRAINT fk_wrk_applcnt_cvfvrcn_applcnt FOREIGN KEY (WRK_BSNS_SN, USER_SN) REFERENCES TN_WRK_APPLCNT (WRK_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청인수혜내용';

-- 일자리신청인연구활동
CREATE TABLE IF NOT EXISTS TN_WRK_APPLCNT_RSRCH_ACT (
    WRK_BSNS_SN            BIGINT       NOT NULL              COMMENT '일자리사업순번',
