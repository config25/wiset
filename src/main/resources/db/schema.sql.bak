    PATENT_APLC_NM        VARCHAR(100)                       COMMENT '특허출원명',
    PATENT_APLC_DE        DATETIME                           COMMENT '특허출원일자',
    PATENT_APLC_NO_NM     VARCHAR(50)                        COMMENT '특허출원번호',
    RGSDE                 DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER              VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                 DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN, USER_SN, DTL_SN),
    CONSTRAINT fk_wrk_applcnt_rsrch_act_applcnt FOREIGN KEY (WRK_BSNS_SN, USER_SN) REFERENCES TN_WRK_APPLCNT (WRK_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청인연구활동';

-- 일자리신청기관경영현황
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_MNGMTS (
    WRK_BSNS_SN            BIGINT        NOT NULL             COMMENT '일자리사업순번',
    BIZRNO                 VARCHAR(12)   NOT NULL             COMMENT '사업자번호',
    STACNT_YEAR            VARCHAR(4)    NOT NULL             COMMENT '결산년도',
