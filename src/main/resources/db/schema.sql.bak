--   ※ FK REQSTQLF_SFEXDOC_SN → TN_WRK_REQINST_SFEXDOC 이나 해당 테이블 미수신 → FK 보류(추후 추가).
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_EXIEM (
    REQSTQLF_SFEXDOC_SN  BIGINT       NOT NULL              COMMENT '신청자격자기진단서순번',
    EXMNTIN_IEM_SN       BIGINT       NOT NULL              COMMENT '진단항목순번',
    UPPER_EXMNTIN_IEM_SN BIGINT       NOT NULL              COMMENT '상위진단항목순번',
    WRITNG_TRGT_SE_CODE  VARCHAR(5)   NOT NULL              COMMENT '작성대상구분코드',
    EXMNTIN_IEM_NM       VARCHAR(200)                       COMMENT '진단항목명',
    DE_IEM_AT            VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '일자항목여부',
    RGSDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER             VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR               VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (REQSTQLF_SFEXDOC_SN, EXMNTIN_IEM_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관자기진단항목';

-- 일자리신청자격진단서
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_SFEXDOC (
    REQSTQLF_SFEXDOC_SN BIGINT       NOT NULL              COMMENT '신청자격진단서순번',
    WRK_BSNS_SE_CODE    VARCHAR(5)   NOT NULL              COMMENT '일자리사업구분코드',
