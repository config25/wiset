    UPDDE               DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR              VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (REQSTQLF_SFEXDOC_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청자격진단서';

-- (보류했던 FK 연결) TN_WRK_REQINST_EXIEM → TN_WRK_REQINST_SFEXDOC
ALTER TABLE TN_WRK_REQINST_EXIEM
    ADD CONSTRAINT fk_wrk_reqinst_exiem_sfexdoc
    FOREIGN KEY (REQSTQLF_SFEXDOC_SN) REFERENCES TN_WRK_REQINST_SFEXDOC (REQSTQLF_SFEXDOC_SN);

-- 일자리신청기관자기진단결과
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_EXRSLT (
    WRK_BSNS_SN         BIGINT       NOT NULL              COMMENT '일자리사업순번',
    BIZRNO              VARCHAR(12)  NOT NULL              COMMENT '사업자번호',
    REQSTQLF_SFEXDOC_SN BIGINT       NOT NULL              COMMENT '신청자격진단서순번',
    EXMNTIN_IEM_SN      BIGINT       NOT NULL              COMMENT '진단항목순번',
    TRGT_AT             VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '대상여부',
    VALID_PD_DE         DATETIME                           COMMENT '유효기간일자',
    RGSDE               DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER            VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE               DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR              VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN, BIZRNO, REQSTQLF_SFEXDOC_SN, EXMNTIN_IEM_SN),
    CONSTRAINT fk_wrk_reqinst_exrslt_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO),
    CONSTRAINT fk_wrk_reqinst_exrslt_exiem FOREIGN KEY (REQSTQLF_SFEXDOC_SN, EXMNTIN_IEM_SN) REFERENCES TN_WRK_REQINST_EXIEM (REQSTQLF_SFEXDOC_SN, EXMNTIN_IEM_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관자기진단결과';

-- 맞춤형교육신청기관
--   ※ FK EDC_BSNS_SN → TN_EDC_CLTME 이나 해당 테이블 미수신 → FK 보류(추후 추가).
CREATE TABLE IF NOT EXISTS TN_EDC_CLTME_REQINST (
    EDC_BSNS_SN          BIGINT       NOT NULL              COMMENT '교육사업순번',
    CLTME_EDC_REQST_SN   BIGINT       NOT NULL              COMMENT '맞춤형교육신청순번',
    USER_SN              BIGINT       NOT NULL              COMMENT '사용자 순번',
    CHARGER_SN           BIGINT       NOT NULL              COMMENT '담당자 순번',
    EDC_REQST_PURPS_NM   VARCHAR(100)                       COMMENT '교육신청목적명',
    EDC_TRGT_CODE        VARCHAR(5)                         COMMENT '교육대상코드',
    EDC_APPLCNT_CO       INT                                COMMENT '교육신청인수',
    EDC_HOPE_DT          DATETIME                           COMMENT '교육 희망 일시',
    EDC_HOPE_TIME        INT                                COMMENT '교육 희망 시간',
    EDC_PLC_NM           VARCHAR(50)                        COMMENT '교육장소명',
    INDVDLINFO_AGRE_AT   VARCHAR(1)   DEFAULT 'N'           COMMENT '개인정보동의여부',
    INSTT_INTRCN_FILE_SN BIGINT                             COMMENT '기관소개파일순번',
    RGSDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER             VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR               VARCHAR(20)  NOT NULL              COMMENT '수정자',
    HOPE_EDC_DTL_MATTER  TEXT                               COMMENT '희망 교육 상세 사항(원본 VARCHAR2(4000))',
    PRIMARY KEY (EDC_BSNS_SN, CLTME_EDC_REQST_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='맞춤형교육신청기관';

-- 맞춤형교육진행이력
CREATE TABLE IF NOT EXISTS TH_EDC_CLTME_PRGRS_HST (
    EDC_BSNS_SN         BIGINT      NOT NULL              COMMENT '교육사업순번',
    CLTME_EDC_REQST_SN  BIGINT      NOT NULL              COMMENT '맞춤형교육신청순번',
    PRGRS_HIST_SN       BIGINT      NOT NULL              COMMENT '진행 이력 순번',
    EDC_PRGRS_STTUS_CODE VARCHAR(5) NOT NULL              COMMENT '교육진행상태코드',
    EDC_PRGRS_RSLT_CODE VARCHAR(5)                        COMMENT '교육진행결과코드',
    RGSDE               DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER            VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (EDC_BSNS_SN, CLTME_EDC_REQST_SN, PRGRS_HIST_SN),
    CONSTRAINT fk_edc_cltme_prgrs_hst_reqinst FOREIGN KEY (EDC_BSNS_SN, CLTME_EDC_REQST_SN) REFERENCES TN_EDC_CLTME_REQINST (EDC_BSNS_SN, CLTME_EDC_REQST_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='맞춤형교육진행이력';

-- 온라인멘토
--   ※ 명세 FK(USER_SN → TH_ONLINE_MNTOR_REQST_HST)는 대상 테이블 미수신·매칭 모호 → FK 보류.
CREATE TABLE IF NOT EXISTS TN_ONLINE_MNTOR (
    ONLINE_MNTOR_SN BIGINT       NOT NULL              COMMENT '온라인멘토순번',
    USER_SN         BIGINT       NOT NULL              COMMENT '사용자순번',
    ACT_BEGIN_DE    DATETIME     NOT NULL              COMMENT '활동시작일자',
    ACT_END_DE      DATETIME     NOT NULL              COMMENT '활동종료일자',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR          VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (ONLINE_MNTOR_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='온라인멘토';

-- 온라인멘토질문
--   ※ 명세 FK(ONLINE_MNTOR_SN → TN_ONLINE_MNTOR)는 부모 PK가 복합(ONLINE_MNTOR_SN, USER_SN)이라
--      단일컬럼으로 매칭 불가 → FK 보류(확인 필요).
CREATE TABLE IF NOT EXISTS TN_ONLINE_MNTOR_QESTN (
    ONLINE_MNTOR_QESTN_SN         BIGINT       NOT NULL              COMMENT '온라인멘토질문순번',
    ONLINE_MNTOR_SN               BIGINT       NOT NULL              COMMENT '온라인멘토순번',
    USER_SN                       BIGINT       NOT NULL              COMMENT '사용자순번',
    RESUME_SN                     BIGINT       NOT NULL              COMMENT '이력서순번',
    QESTN_SJ_NM                   VARCHAR(200)                       COMMENT '질문제목명',
    QESTN_CN                      TEXT                               COMMENT '질문내용(원본 VARCHAR2(4000))',
    NTCE_AT                       VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '게시여부',
    NTCN_SN                       BIGINT                             COMMENT '알림순번',
    FILE_ID                       BIGINT                             COMMENT '파일ID',
    INDVDLINFO_AGRE_AT            VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '개인정보동의여부',
    USER_TY_CODE                  VARCHAR(5)   NOT NULL              COMMENT '사용자유형코드',
    ONLINE_MNTOR_QESTN_STTUS_CODE VARCHAR(5)   NOT NULL              COMMENT '온라인멘토질문상태코드',
    RGSDE                         DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                      VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                         DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                        VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (ONLINE_MNTOR_QESTN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='온라인멘토질문';

-- 온라인멘토답변
CREATE TABLE IF NOT EXISTS TN_ONLINE_MNTOR_ANSWER (
    ONLINE_MNTOR_QESTN_SN BIGINT      NOT NULL              COMMENT '온라인멘토질문순번',
    ANSWER_CN             TEXT                              COMMENT '답변내용(원본 VARCHAR2(4000))',
    FILE_ID               BIGINT                            COMMENT '파일ID',
    NTCN_SN               BIGINT                            COMMENT '알림순번',
    RGSDE                 DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER              VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (ONLINE_MNTOR_QESTN_SN),
    CONSTRAINT fk_online_mntor_answer_qestn FOREIGN KEY (ONLINE_MNTOR_QESTN_SN) REFERENCES TN_ONLINE_MNTOR_QESTN (ONLINE_MNTOR_QESTN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='온라인멘토답변';

-- 사업개인정보동의
CREATE TABLE IF NOT EXISTS TN_BSNS_INDVDLINFO_AGRE (
    INDVDLINFO_AGRE_SN BIGINT       NOT NULL              COMMENT '개인정보동의순번',
    DTL_SN             INT          NOT NULL              COMMENT '상세순번',
    INDVDLINFO_AGRE_AT VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '개인정보동의여부',
    PIN_AGRE_AT        VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '개인식별번호동의여부',
    ASSNTNT_NM         VARCHAR(50)                        COMMENT '동의자명',
    PSITN_INSTT_NM     VARCHAR(100)                       COMMENT '소속기관명',
    OFCPS_NM           VARCHAR(100)                       COMMENT '직위명',
    RSPOFC_NM          VARCHAR(100)                       COMMENT '직책명',
    BRTHDY             VARCHAR(8)                         COMMENT '생년월일',
    SEXDSTN_SE_CODE    VARCHAR(5)                         COMMENT '성별구분코드',
    RGSDE              DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER           VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE              DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR             VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (INDVDLINFO_AGRE_SN, DTL_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='사업개인정보동의';

-- 취업탐색멘토사업
CREATE TABLE IF NOT EXISTS TN_EMPSRCH_BSNS (
    MNTORNG_BSNS_SN      BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    MNTORNG_BSNS_SE_CODE VARCHAR(5)                        COMMENT '멘토링사업구분코드',
    MNTORNG_BSNS_NM      VARCHAR(200)                       COMMENT '멘토링사업명',
    NTCE_AT              VARCHAR(1)   DEFAULT 'N'           COMMENT '게시여부',
    BSNS_BEGIN_DE        DATETIME                           COMMENT '사업시작일자',
    BSNS_END_DE          DATETIME                           COMMENT '사업종료일자',
    MNTOR_RCEPT_BEGIN_DT DATETIME                           COMMENT '멘토접수시작일시',
    MNTOR_RCEPT_END_DT   DATETIME                           COMMENT '멘토접수종료일시',
    MNTEE_RCEPT_BEGIN_DT DATETIME                           COMMENT '멘티접수시작일시',
    MNTEE_RCEPT_END_DT   DATETIME                           COMMENT '멘티접수종료일시',
    MNTEE_1RNK_BEGIN_DT  DATETIME                           COMMENT '멘티1순위시작일시',
    MNTEE_1RNK_END_DT    DATETIME                           COMMENT '멘티1순위종료일시',
    MNTEE_2RNK_BEGIN_DT  DATETIME                           COMMENT '멘티2순위시작일시',
    MNTEE_2RNK_END_DT    DATETIME                           COMMENT '멘티2순위종료일시',
    MNTEE_3RNK_BEGIN_DT  DATETIME                           COMMENT '멘티3순위시작일시',
    MNTEE_3RNK_END_DT    DATETIME                           COMMENT '멘티3순위종료일시',
    MNTEE_4RNK_BEGIN_DT  DATETIME                           COMMENT '멘티4순위시작일시',
    MNTEE_4RNK_END_DT    DATETIME                           COMMENT '멘티4순위종료일시',
    ACT_BEGIN_DE         DATETIME                           COMMENT '활동시작일자',
    ACT_END_DE           DATETIME                           COMMENT '활동종료일자',
    NTCN_SN              BIGINT                             COMMENT '알림순번',
    RGSDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER             VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR               VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (MNTORNG_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='취업탐색멘토사업';

-- 취업탐색사업진행이력
CREATE TABLE IF NOT EXISTS TH_EMPSRCH_BSNS_PRGRS_HST (
    MNTORNG_BSNS_SN               BIGINT      NOT NULL              COMMENT '멘토링사업순번',
    MNTORNG_BSNS_PRGRS_STTUS_CODE VARCHAR(5) NOT NULL              COMMENT '멘토링사업진행상태코드',
    RGSDE                         DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                      VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (MNTORNG_BSNS_SN, MNTORNG_BSNS_PRGRS_STTUS_CODE),
    CONSTRAINT fk_empsrch_bsns_prgrs_hst_bsns FOREIGN KEY (MNTORNG_BSNS_SN) REFERENCES TN_EMPSRCH_BSNS (MNTORNG_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='취업탐색사업진행이력';

-- 취업탐색신청팀
CREATE TABLE IF NOT EXISTS TN_EMPSRCH_REQSTTM (
    MNTORNG_BSNS_SN         BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    USER_SN                 BIGINT       NOT NULL              COMMENT '사용자순번',
    USER_ID                 VARCHAR(20)  NOT NULL              COMMENT '사용자ID',
    PSITN_INSTT_NM          VARCHAR(100)                       COMMENT '소속기관명',
    CLSF_NM                 VARCHAR(100)                       COMMENT '직급명',
    MAJOR_NM                VARCHAR(50)                        COMMENT '전공명',
    LAST_DGRI_NM            VARCHAR(100)                       COMMENT '최종학위명',
    JOB_NM                  TEXT                               COMMENT '업무명(원본 VARCHAR2(4000))',
    MNTORNG_POSBL_RLM_NM    VARCHAR(100)                       COMMENT '멘토링가능분야명',
    REQSTTM_SE_CODE         VARCHAR(5)                         COMMENT '신청팀구분코드',
    REQSTTM_NM              VARCHAR(100)                       COMMENT '신청팀명',
    ACT_AREA_NM             VARCHAR(50)                        COMMENT '활동지역명',
    MNTOR_INTRCN_CN         TEXT                               COMMENT '멘토소개내용(원본 VARCHAR2(4000))',
    MNTOR_ACT_CN            TEXT                               COMMENT '멘토활동내용(원본 VARCHAR2(4000))',
    MNTORNG_POSBL_CN        TEXT                               COMMENT '멘토링가능내용(원본 VARCHAR2(4000))',
    MNTORNG_GOAL_CN         TEXT                               COMMENT '멘토링목표내용(원본 VARCHAR2(4000))',
    MNTORNG_EXPFT_CN        TEXT                               COMMENT '멘토링기대효과내용(원본 VARCHAR2(4000))',
    ETC_CN                  VARCHAR(50)                        COMMENT '기타내용',
    ACT_BEGIN_DE            DATETIME                           COMMENT '활동시작일자',
    ACT_END_DE             DATETIME                           COMMENT '활동종료일자',
    PARTCPTN_POSBL_MNTEE_CO INT                               COMMENT '참여가능멘티수',
    FILE_ID                 BIGINT                             COMMENT '파일 ID',
    PRGRS_STTUS_CODE        VARCHAR(5)                         COMMENT '진행상태코드',
    EVAL_RSLT_CODE          VARCHAR(5)                         COMMENT '평가결과코드',
    PRGRS_RSLT_CODE         VARCHAR(5)                         COMMENT '진행결과코드',
    PRGRS_RSLT_CN           TEXT                               COMMENT '진행결과내용(원본 VARCHAR2(4000))',
    REQSTDOC_AGRE_AT        VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '신청서동의여부',
    INDVDLINFO_AGRE_SN      BIGINT                             COMMENT '개인정보동의순번',
    REQST_DE                DATETIME                           COMMENT '신청일자',
    COMPL_AT                VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '수료여부',
    RGSDE                   DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                   DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                  VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (MNTORNG_BSNS_SN, USER_SN, USER_ID),
    CONSTRAINT fk_empsrch_reqsttm_bsns FOREIGN KEY (MNTORNG_BSNS_SN) REFERENCES TN_EMPSRCH_BSNS (MNTORNG_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='취업탐색신청팀';

-- 취업탐색신청팀참여자
CREATE TABLE IF NOT EXISTS TN_EMPSRCH_REQSTTM_PRTCPNT (
    MNTORNG_BSNS_SN      BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    USER_SN              BIGINT       NOT NULL              COMMENT '사용자순번',
    REPRSNT_USER_ID      VARCHAR(20)                        COMMENT '대표사용자ID',
    PSITN_INSTT_NM       VARCHAR(100)                       COMMENT '소속기관명',
    CLSF_NM              VARCHAR(100)                       COMMENT '직급명',
    MAJOR_NM             VARCHAR(50)                        COMMENT '전공명',
    LAST_DGRI_NM         VARCHAR(100)                       COMMENT '최종학위명',
    JOB_NM               TEXT                               COMMENT '업무명(원본 VARCHAR2(4000))',
    MNTORNG_POSBL_RLM_NM VARCHAR(100)                       COMMENT '멘토링가능분야명',
    PRGRS_STTUS_CODE     VARCHAR(5)                         COMMENT '진행상태코드',
    PRGRS_RSLT_CODE      VARCHAR(5)                         COMMENT '진행결과코드',
    EVAL_RSLT_CODE       VARCHAR(5)                         COMMENT '평가결과코드',
    PRGRS_RSLT_CN        TEXT                               COMMENT '진행결과내용(원본 VARCHAR2(4000))',
    REQSTDOC_AGRE_AT     VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '신청서동의여부',
    INDVDLINFO_AGRE_SN   BIGINT                             COMMENT '개인정보동의순번',
    REQST_DE             DATETIME                           COMMENT '신청일자',
    COMPL_AT             VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '수료여부',
    RGSDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER             VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR               VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (MNTORNG_BSNS_SN, USER_SN),
    CONSTRAINT fk_empsrch_reqsttm_prtcpnt_bsns FOREIGN KEY (MNTORNG_BSNS_SN) REFERENCES TN_EMPSRCH_BSNS (MNTORNG_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='취업탐색신청팀참여자';

-- 취업탐색신청팀활동계획
--   ※ FK (MNTORNG_BSNS_SN, USER_SN)→TN_EMPSRCH_REQSTTM 이나 부모 PK가 3컬럼
--      (…, USER_ID 포함)이라 2컬럼 매칭 불가 → FK 보류(확인 필요).
CREATE TABLE IF NOT EXISTS TN_EMPSRCH_REQSTTM_PLAN (
    MNTORNG_BSNS_SN BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    USER_SN         BIGINT       NOT NULL              COMMENT '사용자순번',
    DTL_SN          INT          NOT NULL              COMMENT '상세순번',
    ACT_MONTH       VARCHAR(2)   NOT NULL              COMMENT '활동개월',
    ACT_SJ_NM       VARCHAR(200)                       COMMENT '활동제목명',
    ACT_CN          TEXT                               COMMENT '활동내용(원본 VARCHAR2(4000))',
    ACT_PLC_NM      VARCHAR(200)                       COMMENT '활동장소명',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR          VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (MNTORNG_BSNS_SN, USER_SN, DTL_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='취업탐색신청팀활동계획';

-- 취업탐색멘티
CREATE TABLE IF NOT EXISTS TN_EMPSRCH_MNTEE (
    MNTORNG_BSNS_SN          BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    USER_SN                  BIGINT       NOT NULL              COMMENT '사용자순번',
    WISET_ID                 VARCHAR(20)                        COMMENT 'WISET ID',
    MNTEE_REQST_TRGT_SE_CODE VARCHAR(5)                         COMMENT '멘티신청대상구분코드',
    MNTEE_REQST_TRGT_ETC_NM  VARCHAR(100)                       COMMENT '멘티신청대상기타명',
    PSITN_INSTT_NM           VARCHAR(100)                       COMMENT '소속기관명',
    MAJOR_NM                 VARCHAR(50)                        COMMENT '전공명',
    GRADE                    INT                                COMMENT '학년',
    SEMSTR                   INT                                COMMENT '학기',
    GRDTN_PRERNG_YEAR        VARCHAR(4)                         COMMENT '졸업예정년도',
    HOPE_1RNK_NM             VARCHAR(100)                       COMMENT '희망1순위명',
    HOPE_1RNK_USER_SN        BIGINT                             COMMENT '1순위사용자순번',
    HOPE_2RNK_NM             VARCHAR(100)                       COMMENT '희망2순위명',
    HOPE_2RNK_USER_SN        BIGINT                             COMMENT '2순위사용자순번',
    HOPE_3RNK_NM             VARCHAR(100)                       COMMENT '희망3순위명',
    HOPE_3RNK_USER_SN        BIGINT                             COMMENT '3순위사용자순번',
    SELF_INTRCN_CN           TEXT                               COMMENT '자기 소개 내용(원본 VARCHAR2(4000))',
    SPORT_SYNC_CN            TEXT                               COMMENT '지원동기내용(원본 VARCHAR2(4000))',
    ACT_CN                   TEXT                               COMMENT '활동 내용(원본 VARCHAR2(4000))',
    PRGRS_STTUS_CODE         VARCHAR(5)                         COMMENT '진행상태코드',
    PRGRS_RSLT_CODE          VARCHAR(5)                         COMMENT '진행결과코드',
    EVAL_RSLT_CODE           VARCHAR(5)                         COMMENT '평가결과코드',
    PRGRS_RSLT_CN            TEXT                               COMMENT '진행결과내용(원본 VARCHAR2(4000))',
    REQSTDOC_AGRE_AT         VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '신청서동의여부',
    INDVDLINFO_AGRE_SN       BIGINT                             COMMENT '개인정보동의순번',
    REQST_DE                 DATETIME                           COMMENT '신청일자',
    COMPL_AT                 VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '수료여부',
    RGSDE                    DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                 VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                    DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                   VARCHAR(20)  NOT NULL              COMMENT '수정자',
    RESDNC                   VARCHAR(100)                       COMMENT '거주지(이전데이터)',
    PARTCPTN_AT              VARCHAR(1)                         COMMENT '참여 여부(이전데이터)',
    PARTCPTN_YEAR            VARCHAR(4)                         COMMENT '참여 년도(이전데이터)',
    PARTCPTN_PROGRM_NM       VARCHAR(200)                       COMMENT '참여 프로그램 명(이전데이터)',
    FILE_ID                  BIGINT                             COMMENT '파일 ID(이전데이터)',
    PRIMARY KEY (MNTORNG_BSNS_SN, USER_SN),
    CONSTRAINT fk_empsrch_mntee_bsns FOREIGN KEY (MNTORNG_BSNS_SN) REFERENCES TN_EMPSRCH_BSNS (MNTORNG_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='취업탐색멘티';

-- 게시물 관리
CREATE TABLE IF NOT EXISTS TN_NTT_INFO (
    NTT_SN         BIGINT       NOT NULL              COMMENT '게시물 순번',
    DIV_CODE       VARCHAR(18)  NOT NULL              COMMENT '구분내용 코드',
    REPLY_SN       BIGINT                             COMMENT '답글 순번',
    NTT_SJ         VARCHAR(255) NOT NULL              COMMENT '게시물 제목',
    NTT_CN         LONGTEXT                           COMMENT '게시물 내용(원본 CLOB)',
    NTT_CODE       VARCHAR(5)                         COMMENT '게시물 코드',
    NTT_PW         VARCHAR(255)                       COMMENT '게시물 비밀번호',
    PBLICTE_DE     VARCHAR(8)                         COMMENT '발행 일자',
    WRTER          VARCHAR(16)                        COMMENT '작성자',
    RDCNT          INT          DEFAULT 0             COMMENT '조회수',
    FILE_ID        BIGINT                             COMMENT '파일 ID',
    DELETE_AT      CHAR(1)      NOT NULL DEFAULT 'N'  COMMENT '삭제 여부',
    POPUP_AT       VARCHAR(1)   DEFAULT 'N'           COMMENT '팝업 여부',
    UPEND_NTCE_AT  VARCHAR(1)   DEFAULT 'N'           COMMENT '상단 게시 여부',
    USE_AT         VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '사용여부',
    NTT_KWRD       VARCHAR(255)                       COMMENT '게시물 키워드',
    LINK_AT        VARCHAR(1)   DEFAULT 'N'           COMMENT '링크 여부',
    LINK_URL       VARCHAR(100)                       COMMENT '링크URL',
    ASSTN_LINK_URL VARCHAR(100)                       COMMENT '보조 링크 URL',
    RGSDE          DATETIME     DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER       VARCHAR(20)                        COMMENT '등록자',
    UPDDE          DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR         VARCHAR(20)                        COMMENT '수정자',
    PRIMARY KEY (NTT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='게시물 관리';

-- 교육정보 (교육사업 1:1 상세)
CREATE TABLE IF NOT EXISTS TN_EDC_INFO (
    EDC_BSNS_SN        BIGINT       NOT NULL              COMMENT '교육사업순번',
    ONLINE_EDC_TY_CODE VARCHAR(5)                         COMMENT '온라인교육유형코드',
    SET_EDC_TY_CODE    VARCHAR(5)                         COMMENT '집합교육유형코드',
    EDC_NM             VARCHAR(100)                       COMMENT '교육명',
    EDC_PURPS_NM       VARCHAR(200)                       COMMENT '교육목적명',
    EDC_CN             LONGTEXT                           COMMENT '교육내용(원본 CLOB)',
    EDC_PSNCPA_CO      INT                                COMMENT '교육정원수',
    DAY1_EDC_TIME      DATETIME                           COMMENT '1일교육시간',
    RCEPT_BEGIN_DT     DATETIME                           COMMENT '접수시작일시',
    RCEPT_END_DT       DATETIME                           COMMENT '접수종료일시',
    PEPSPLMN_BEGIN_DT  DATETIME                           COMMENT '서류보완시작일시',
    PEPSPLMN_END_DT    DATETIME                           COMMENT '서류보완종료일시',
    EDC_BEGIN_DE       DATETIME                           COMMENT '교육시작일자',
    EDC_END_DE         DATETIME                           COMMENT '교육종료일자',
    COMPL_NO_FOM       VARCHAR(100)                       COMMENT '수료 번호 형식',
    RDCNT              INT          DEFAULT 0             COMMENT '조회수',
    RGSDE              DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER           VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE              DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR             VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (EDC_BSNS_SN),
    CONSTRAINT fk_edc_info_bsns FOREIGN KEY (EDC_BSNS_SN) REFERENCES TN_EDC_BSNS (EDC_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='교육정보';

-- 교육진행이력
CREATE TABLE IF NOT EXISTS TH_EDC_PRGRS_HST (
    EDC_BSNS_SN         BIGINT      NOT NULL              COMMENT '교육사업순번',
    EDC_PRGRS_STTUS_CODE VARCHAR(5) NOT NULL              COMMENT '교육진행상태코드',
    RGSDE               DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER            VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (EDC_BSNS_SN, EDC_PRGRS_STTUS_CODE),
    CONSTRAINT fk_edc_prgrs_hst_bsns FOREIGN KEY (EDC_BSNS_SN) REFERENCES TN_EDC_BSNS (EDC_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='교육진행이력';

-- 이력서 학력
--   ※ FK RESUME_SN → TN_RESUME 이나 해당 테이블 미수신 → FK 보류(추후 추가).
CREATE TABLE IF NOT EXISTS TN_RESUME_ACDMCR (
    ACDMCR_SN         BIGINT       NOT NULL              COMMENT '학력 순번',
    RESUME_SN         BIGINT       NOT NULL              COMMENT '이력서순번',
    SCHUL_NM          VARCHAR(100) NOT NULL              COMMENT '학교 명',
    ACDMCR_BEGIN_DE   VARCHAR(12)                        COMMENT '학력 시작 일자',
    ACDMCR_END_DE     VARCHAR(12)                        COMMENT '학력 종료 일자',
    ACDMCR_SE_CODE    VARCHAR(5)                         COMMENT '학력 구분 코드',
    MAJOR_NM          VARCHAR(50)                        COMMENT '전공명',
    PNT               DECIMAL(5,2)                       COMMENT '학점',
    TOTALPNT          DECIMAL(5,2)                       COMMENT '총점',
    THESIS_CN         VARCHAR(200)                       COMMENT '논문 내용',
    REGISTER          VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE             DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR            VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE             DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    ACDMCR_CODE       VARCHAR(5)                         COMMENT '학력 코드',
    AREA_NM           VARCHAR(50)                        COMMENT '지역 명',
    LAST_DGRI_SE_CODE VARCHAR(5)                         COMMENT '최종학위구분코드',
    PRIMARY KEY (ACDMCR_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 학력';

-- 이력서 자기소개  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_SELF_INTRCN (
    SELF_INTRCN_SN BIGINT       NOT NULL              COMMENT '자기 소개 순번',
    RESUME_SN      BIGINT       NOT NULL              COMMENT '이력서순번',
    SELF_INTRCN_SJ VARCHAR(200)                       COMMENT '자기 소개 제목',
    REGISTER       VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE          DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR         VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE          DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    SELF_INTRCN_CN TEXT                               COMMENT '자기 소개 내용(원본 VARCHAR2(4000))',
    PRIMARY KEY (SELF_INTRCN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 자기소개';

-- 이력서 경력  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_CAREER (
    CAREER_SN       BIGINT       NOT NULL              COMMENT '경력 순번',
    RESUME_SN       BIGINT       NOT NULL              COMMENT '이력서순번',
    CAREER_INSTT_NM VARCHAR(100)                       COMMENT '경력 기관 명',
    DEPT_NM         VARCHAR(50)                        COMMENT '부서 명',
    CLSF_NM         VARCHAR(100)                       COMMENT '직급명',
    DTY_NM          VARCHAR(100)                       COMMENT '직무 명',
    ANSLRY_AM       BIGINT                             COMMENT '연봉금액',
    CAREER_CN       TEXT                               COMMENT '경력내용(원본 VARCHAR2(4000))',
    CAREER_BEGIN_DE VARCHAR(10)                        COMMENT '경력 시작 일자',
    CAREER_END_DE   VARCHAR(12)                        COMMENT '경력 종료 일자',
    RETIRE_RESN_CN  VARCHAR(100)                       COMMENT '퇴직 사유 내용',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR          VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (CAREER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 경력';

-- 이력서 포트폴리오 URL  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_PRTFOLIO_URL (
    PRTFOLIO_URL_SN BIGINT       NOT NULL              COMMENT '포트폴리오 URL 순번',
    RESUME_SN       BIGINT       NOT NULL              COMMENT '이력서순번',
    PRTFOLIO_URL    VARCHAR(100) NOT NULL              COMMENT '포트폴리오 URL',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR          VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (PRTFOLIO_URL_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 포트폴리오 URL';

-- 이력서 자격증  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_CRQFC (
    CRQFC_SN         BIGINT       NOT NULL              COMMENT '자격증 순번',
    RESUME_SN        BIGINT       NOT NULL              COMMENT '이력서순번',
    CRQFC_NM         VARCHAR(100) NOT NULL              COMMENT '자격증명',
    ACQS_DE          DATETIME                           COMMENT '취득 일자',
    MTD              VARCHAR(5)                         COMMENT '만기일',
    PBLICTE_INSTT_NM VARCHAR(50)                        COMMENT '발행기관명',
    REGISTER         VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR           VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (CRQFC_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 자격증';

-- 이력서 교육연수  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_EDC (
    EDC_SN       BIGINT       NOT NULL              COMMENT '교육순번',
    RESUME_SN    BIGINT       NOT NULL              COMMENT '이력서순번',
    EDC_NM       VARCHAR(100)                       COMMENT '교육명',
    EDC_BEGIN_DE DATETIME                           COMMENT '교육시작일자',
    EDC_END_DE   DATETIME                           COMMENT '교육종료일자',
    EDC_INSTT_NM VARCHAR(50)                        COMMENT '교육기관명',
    EDC_CN       LONGTEXT                           COMMENT '교육내용(원본 CLOB)',
    REGISTER     VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE        DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR       VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE        DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EDC_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 교육연수';

-- 이력서 활동  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_ACT (
    ACT_SN       BIGINT       NOT NULL              COMMENT '활동 순번',
    RESUME_SN    BIGINT       NOT NULL              COMMENT '이력서순번',
    ACT_SE_CODE  VARCHAR(5)   NOT NULL              COMMENT '활동 구분 코드',
    ACT_INSTT_NM VARCHAR(100)                       COMMENT '활동 기관 명',
    ACT_BEGIN_DE DATETIME                           COMMENT '활동시작일자',
    ACT_END_DE   DATETIME                           COMMENT '활동종료일자',
    ACT_CN       TEXT                               COMMENT '활동 내용(원본 VARCHAR2(4000))',
    REGISTER     VARCHAR(20)                        COMMENT '등록자',
    RGSDE        DATETIME     DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR       VARCHAR(20)                        COMMENT '수정자',
    UPDDE        DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (ACT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 활동';

-- 이력서 수상  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_WNPZ (
    WNPZ_SN       BIGINT       NOT NULL              COMMENT '수상 순번',
    RESUME_SN     BIGINT       NOT NULL              COMMENT '이력서순번',
    WNPZ_NM       VARCHAR(100) NOT NULL              COMMENT '수상 명',
    WNPZ_INSTT_NM VARCHAR(100)                       COMMENT '수상 기관 명',
    WNPZ_YEAR     VARCHAR(4)                         COMMENT '수상 년도',
    WNPZ_CN       TEXT                               COMMENT '수상 내용(원본 VARCHAR2(4000))',
    RGSDE         DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER      VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDUSR        VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE         DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (WNPZ_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 수상';

-- 이력서 해외경험  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_OVSEA (
    OVSEA_SN       BIGINT       NOT NULL              COMMENT '해외 순번',
    RESUME_SN      BIGINT       NOT NULL              COMMENT '이력서순번',
    OVSEA_NM       VARCHAR(100)                       COMMENT '해외 명',
    OVSEA_BEGIN_DE VARCHAR(7)                         COMMENT '해외 시작 일자',
    OVSEA_END_DE   VARCHAR(7)                         COMMENT '해외 종료 일자',
    OVSEA_CN       TEXT                               COMMENT '해외 내용(원본 VARCHAR2(4000))',
    REGISTER       VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE          DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR         VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE          DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (OVSEA_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 해외경험';

-- 이력서 어학  (※ FK RESUME_SN → TN_RESUME 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_RESUME_LSTCS (
    LSTCS_SN         BIGINT       NOT NULL              COMMENT '어학 순번',
    RESUME_SN        BIGINT       NOT NULL              COMMENT '이력서순번',
    LSTCS_CODE       VARCHAR(5)   NOT NULL              COMMENT '어학 코드',
    LSTCS_SE_CODE    VARCHAR(5)                         COMMENT '어학 구분 코드',
    LSTCS_NM         VARCHAR(50)                        COMMENT '어학 명',
    LSTCS_ABLTY_CODE VARCHAR(5)                         COMMENT '어학 능력 코드',
    REGISTER         VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR           VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    LSTCS_KIND       VARCHAR(200)                       COMMENT '어학 종류',
    LSTCS_POINT      VARCHAR(100)                       COMMENT '어학 점수',
    PRIMARY KEY (LSTCS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 어학';

-- 지역 코드
CREATE TABLE IF NOT EXISTS TN_AREA_CODE (
    AREA_SN       BIGINT      NOT NULL AUTO_INCREMENT COMMENT '지역 순번',
    AREA_NM       VARCHAR(50)                         COMMENT '지역 명',
    UPPER_AREA_SN BIGINT                              COMMENT '상위 지역 순번',
    PRIMARY KEY (AREA_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='지역 코드';

-- 고정문항정보
CREATE TABLE IF NOT EXISTS TN_FIXING_QESITM_INFO (
    QESITM_SN       BIGINT        NOT NULL              COMMENT '문항 순번',
    SVC_SE          VARCHAR(18)   NOT NULL              COMMENT '서비스 구분',
    DIV_CODE        VARCHAR(18)   NOT NULL              COMMENT '구분내용 코드',
    UPPER_QESITM_SN BIGINT                              COMMENT '상위 문항 순번',
    QESITM_TY       VARCHAR(18)                         COMMENT '문항 유형',
    QESITM_CN       VARCHAR(1000)                       COMMENT '문항 내용',
    BASS_INFO_AT    VARCHAR(1)    DEFAULT 'N'           COMMENT '기본 정보 여부',
    ETC_INPUT_AT    VARCHAR(1)    DEFAULT 'N'           COMMENT '기타 입력 여부',
    USE_AT          VARCHAR(1)    NOT NULL DEFAULT 'N'  COMMENT '사용여부',
    QESITM_TOTALPNT INT           DEFAULT 0             COMMENT '문항 총점',
    RGSDE           DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER        VARCHAR(20)   NOT NULL              COMMENT '등록자',
    UPDDE           DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR          VARCHAR(20)                         COMMENT '수정자',
    PRIMARY KEY (QESITM_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='고정문항정보';

-- 고정 답변 정보
CREATE TABLE IF NOT EXISTS TN_FIXING_ANSWER_INFO (
    QESITM_SN        BIGINT        NOT NULL              COMMENT '문항 번호',
    ANSWER_SN        BIGINT        NOT NULL              COMMENT '답변 순번',
    ANSWER_QESITM_CN VARCHAR(1000) NOT NULL              COMMENT '답변 문항 내용',
    ANSWER_SCR       INT           DEFAULT 0             COMMENT '답변 점수',
    REGISTER         VARCHAR(20)   NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR           VARCHAR(20)                         COMMENT '수정자',
    UPDDE            DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (QESITM_SN, ANSWER_SN),
    CONSTRAINT fk_fixing_answer_qesitm FOREIGN KEY (QESITM_SN) REFERENCES TN_FIXING_QESITM_INFO (QESITM_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='고정 답변 정보';

-- 조사폼 정보
CREATE TABLE IF NOT EXISTS TN_EXAMIN_FORM_INFO (
    EXAMIN_SN       BIGINT       NOT NULL              COMMENT '조사 순번',
    SVC_SE          VARCHAR(18)  NOT NULL              COMMENT '서비스 구분',
    DIV_CODE        VARCHAR(18)  NOT NULL              COMMENT '구분내용 코드',
    DIV_DTL_CODE    VARCHAR(5)                         COMMENT '구분내용 상세 코드',
    DIV_CL_CODE     VARCHAR(5)                         COMMENT '구분내용 분류 코드',
    EXAMIN_NM       VARCHAR(255) NOT NULL              COMMENT '조사 명',
    EXAMIN_CNTC_SN  BIGINT       NOT NULL              COMMENT '조사 연계 순번',
    TOTALPNT        INT          DEFAULT 0             COMMENT '총점',
    EXAMIN_BEGIN_DT DATETIME                           COMMENT '조사 시작 일시',
    EXAMIN_END_DT   DATETIME                           COMMENT '조사 종료 일시',
    NTCN_AT         VARCHAR(1)   DEFAULT 'N'           COMMENT '알림여부',
    NTCN_SN         BIGINT                             COMMENT '알림순번',
    USE_AT          VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '사용여부',
    DELETE_AT       CHAR(1)      NOT NULL DEFAULT 'N'  COMMENT '삭제 여부',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR          VARCHAR(20)                        COMMENT '수정자',
    UPDDE           DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXAMIN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='조사폼 정보';

-- 조사 문항 정보
CREATE TABLE IF NOT EXISTS TN_EXAMIN_QESITM_INFO (
    EXAMIN_SN        BIGINT        NOT NULL              COMMENT '조사 순번',
    QESITM_SN        BIGINT        NOT NULL              COMMENT '문항 번호',
    UPPER_QESITM_SN  BIGINT                              COMMENT '상위 문항 순번',
    QESITM_TY        VARCHAR(18)                         COMMENT '문항 유형',
    QESITM_CN        VARCHAR(1000)                       COMMENT '문항 내용',
    FIXING_QESITM_AT VARCHAR(1)    NOT NULL DEFAULT 'N'  COMMENT '고정 문항 여부',
    BASS_INFO_AT     VARCHAR(1)    DEFAULT 'N'           COMMENT '기본 정보 여부',
    ETC_INPUT_AT     VARCHAR(1)                          COMMENT '기타 입력 여부',
    QESITM_TOTALPNT  INT           DEFAULT 0             COMMENT '문항 총점',
    DELETE_AT        CHAR(1)       DEFAULT 'N'           COMMENT '삭제 여부',
    REGISTER         VARCHAR(20)   NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR           VARCHAR(20)                         COMMENT '수정자',
    UPDDE            DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXAMIN_SN, QESITM_SN),
    CONSTRAINT fk_examin_qesitm_form FOREIGN KEY (EXAMIN_SN) REFERENCES TN_EXAMIN_FORM_INFO (EXAMIN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='조사 문항 정보';

-- 조사 답변 정보
CREATE TABLE IF NOT EXISTS TN_EXAMIN_ANSWER_INFO (
    EXAMIN_SN        BIGINT        NOT NULL              COMMENT '조사 순번',
    QESITM_SN        BIGINT        NOT NULL              COMMENT '문항 번호',
    ANSWER_SN        BIGINT        NOT NULL              COMMENT '답변 순번',
    ANSWER_QESITM_CN VARCHAR(1000) NOT NULL              COMMENT '답변 문항 내용',
    ANSWER_SCR       INT           DEFAULT 0             COMMENT '답변 점수',
    DELETE_AT        CHAR(1)       DEFAULT 'N'           COMMENT '삭제 여부',
    REGISTER         VARCHAR(20)   NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR           VARCHAR(20)                         COMMENT '수정자',
    UPDDE            DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXAMIN_SN, QESITM_SN, ANSWER_SN),
    CONSTRAINT fk_examin_answer_qesitm FOREIGN KEY (EXAMIN_SN, QESITM_SN) REFERENCES TN_EXAMIN_QESITM_INFO (EXAMIN_SN, QESITM_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='조사 답변 정보';

-- 조사 참여 정보
CREATE TABLE IF NOT EXISTS TN_EXAMIN_PARTCPTN_INFO (
    EXAMIN_PARTCPTN_SN BIGINT        NOT NULL              COMMENT '조사 참여 순번',
    EXAMIN_SN          BIGINT        NOT NULL              COMMENT '조사 순번',
    QESITM_SN          BIGINT        NOT NULL              COMMENT '문항 순번',
    CHOISE_ANSWER_SN   BIGINT        NOT NULL              COMMENT '선택 답변 순번',
    CHOISE_ANSWER_INFO VARCHAR(100)                        COMMENT '선택 답변 정보',
    CHOISE_ANSWER_SCR  INT                                 COMMENT '선택 답변 점수',
    SBJCT_ANSWER_CN    TEXT                                COMMENT '주관식 답변 내용(원본 VARCHAR2(4000))',
    DELETE_AT          CHAR(1)       DEFAULT 'N'           COMMENT '삭제 여부',
    EXAMIN_COMPT_AT    VARCHAR(1)    DEFAULT 'N'           COMMENT '조사 완료 여부',
    PRTCPNT_ID         VARCHAR(20)   NOT NULL              COMMENT '참여자 ID',
    EXAMIN_PARTCPTN_DE DATETIME      DEFAULT CURRENT_TIMESTAMP COMMENT '조사 참여 일자',
    REGISTER           VARCHAR(20)   NOT NULL              COMMENT '등록자',
    RGSDE              DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR             VARCHAR(20)                         COMMENT '수정자',
    UPDDE              DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXAMIN_PARTCPTN_SN, EXAMIN_SN, QESITM_SN, CHOISE_ANSWER_SN),
    CONSTRAINT fk_examin_partcptn_qesitm FOREIGN KEY (EXAMIN_SN, QESITM_SN) REFERENCES TN_EXAMIN_QESITM_INFO (EXAMIN_SN, QESITM_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='조사 참여 정보';

-- 맞춤형교육
CREATE TABLE IF NOT EXISTS TN_EDC_CLTME (
    EDC_BSNS_SN         BIGINT       NOT NULL              COMMENT '교육사업순번',
    EDC_YEAR            VARCHAR(4)   NOT NULL              COMMENT '교육년도',
    CLTME_EDC_TRGT_CODE VARCHAR(5)   NOT NULL              COMMENT '맞춤형교육대상코드',
    CLTME_EDC_NM        VARCHAR(200) NOT NULL              COMMENT '맞춤형교육명',
    RCEPT_BEGIN_DT      DATETIME     NOT NULL              COMMENT '접수시작일시',
    RCEPT_END_DT        DATETIME     NOT NULL              COMMENT '접수종료일시',
    EDC_BEGIN_DT        DATETIME     NOT NULL              COMMENT '교육시작일시',
    EDC_END_DT          DATETIME     NOT NULL              COMMENT '교육종료일시',
    EDC_REQST_CND_CN    TEXT                               COMMENT '교육신청조건내용(원본 VARCHAR2(4000))',
    RGSDE               DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER            VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE               DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR              VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (EDC_BSNS_SN),
    CONSTRAINT fk_edc_cltme_bsns FOREIGN KEY (EDC_BSNS_SN) REFERENCES TN_EDC_BSNS (EDC_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='맞춤형교육';

-- (보류했던 FK 연결) TN_EDC_CLTME_REQINST → TN_EDC_CLTME
ALTER TABLE TN_EDC_CLTME_REQINST
    ADD CONSTRAINT fk_edc_cltme_reqinst_cltme
    FOREIGN KEY (EDC_BSNS_SN) REFERENCES TN_EDC_CLTME (EDC_BSNS_SN);

-- 교육교과과정
CREATE TABLE IF NOT EXISTS TN_EDC_CRCLM (
    EDC_BSNS_SN      BIGINT       NOT NULL              COMMENT '교육사업순번',
    CRCLM_SN         BIGINT       NOT NULL              COMMENT '교과과정순번',
    CRCLM_NM         VARCHAR(200) NOT NULL              COMMENT '교과과정명',
    INSTRCTR_USER_SN BIGINT       NOT NULL              COMMENT '강사사용자순번',
    RGSDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER         VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR           VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (EDC_BSNS_SN, CRCLM_SN),
    CONSTRAINT fk_edc_crclm_info FOREIGN KEY (EDC_BSNS_SN) REFERENCES TN_EDC_INFO (EDC_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='교육교과과정';

-- 맞춤형교육신청내용
--   ※ FK 대상 TN_EDC_CLTME_CRCLM 미수신 → FK 보류(추후 추가).
CREATE TABLE IF NOT EXISTS TN_EDC_CLTME_REQST_CN (
    EDC_BSNS_SN        BIGINT      NOT NULL              COMMENT '교육사업순번',
    CLTME_EDC_REQST_SN BIGINT      NOT NULL              COMMENT '맞춤형교육신청순번',
    CRCLM_SN           BIGINT      NOT NULL              COMMENT '교과과정순번',
    INSTRCTR_SN        BIGINT                            COMMENT '강사순번',
    INSTRCTR_DCSN_AT   VARCHAR(1)  DEFAULT 'N'           COMMENT '강사확정여부',
    INSTRCTR_SPORT_AT  VARCHAR(1)  DEFAULT 'N'           COMMENT '강사지원여부',
    RGSDE              DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER           VARCHAR(20) NOT NULL              COMMENT '등록자',
    UPDDE              DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR             VARCHAR(20) NOT NULL              COMMENT '수정자',
    PRIMARY KEY (EDC_BSNS_SN, CLTME_EDC_REQST_SN, CRCLM_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='맞춤형교육신청내용';

-- 맞춤형교육과정
CREATE TABLE IF NOT EXISTS TN_EDC_CLTME_CRCLM (
    EDC_BSNS_SN     BIGINT       NOT NULL              COMMENT '교육사업순번',
    CRCLM_SN        BIGINT       NOT NULL              COMMENT '교과과정순번',
    CLTME_EDC_SE_NM VARCHAR(50)  NOT NULL              COMMENT '맞춤형교육구분명',
    EDC_THEMA_NM    VARCHAR(50)  NOT NULL              COMMENT '교육테마명',
    EDC_NM          VARCHAR(100) NOT NULL              COMMENT '교육명',
    EDC_NO_NM       VARCHAR(50)  NOT NULL              COMMENT '교육번호명',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR          VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (EDC_BSNS_SN, CRCLM_SN),
    CONSTRAINT fk_edc_cltme_crclm_cltme FOREIGN KEY (EDC_BSNS_SN) REFERENCES TN_EDC_CLTME (EDC_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='맞춤형교육과정';

-- (보류했던 FK 연결) TN_EDC_CLTME_REQST_CN → 교과과정/신청
ALTER TABLE TN_EDC_CLTME_REQST_CN
    ADD CONSTRAINT fk_edc_cltme_reqst_cn_crclm
    FOREIGN KEY (EDC_BSNS_SN, CRCLM_SN) REFERENCES TN_EDC_CLTME_CRCLM (EDC_BSNS_SN, CRCLM_SN);
ALTER TABLE TN_EDC_CLTME_REQST_CN
    ADD CONSTRAINT fk_edc_cltme_reqst_cn_reqinst
    FOREIGN KEY (EDC_BSNS_SN, CLTME_EDC_REQST_SN) REFERENCES TN_EDC_CLTME_REQINST (EDC_BSNS_SN, CLTME_EDC_REQST_SN);

-- 알림설정
CREATE TABLE IF NOT EXISTS TN_NTCN_ESTBS (
    NTCN_SN          BIGINT       NOT NULL              COMMENT '알림순번',
    NTCN_DTL_SN      BIGINT       NOT NULL              COMMENT '알림상세순번',
    NTCN_IEM_CODE    VARCHAR(5)   NOT NULL              COMMENT '알림항목코드',
    NTCN_STTUS_CODE  VARCHAR(5)   NOT NULL              COMMENT '알림상태코드',
    NTCN_CN          TEXT                               COMMENT '알림내용(원본 VARCHAR2(4000))',
    NTCN_SNDNG_DT    DATETIME     NOT NULL              COMMENT '알림발송일시',
    SVC_SE           VARCHAR(18)                        COMMENT '서비스 구분',
    DIV_CODE         VARCHAR(18)                        COMMENT '구분내용 코드',
    PRGRS_STTUS_CODE VARCHAR(5)                         COMMENT '진행상태코드',
    RGSDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER         VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR           VARCHAR(20)  NOT NULL              COMMENT '수정자',
    KATK_CODE        VARCHAR(5)                         COMMENT '알림톡코드',
    PRIMARY KEY (NTCN_SN, NTCN_DTL_SN, NTCN_IEM_CODE)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='알림설정';

-- 컨설턴트 정보
CREATE TABLE IF NOT EXISTS TN_CNSTNT_INFO (
    CNSTNT_SN            BIGINT       NOT NULL              COMMENT '컨설턴트 순번',
    USER_SN              BIGINT       NOT NULL              COMMENT '사용자 순번',
    CNSL_TOPIC_CODE      VARCHAR(5)   NOT NULL              COMMENT '컨설팅 주제 코드',
    CNSL_RLM_CODE        VARCHAR(5)   NOT NULL              COMMENT '컨설팅 분야 코드',
    CNSL_SPCLTY_RLM      TEXT                               COMMENT '컨설팅 전문 분야(원본 VARCHAR2(4000))',
    CNSL_POSBL_TRGT_CODE VARCHAR(5)                         COMMENT '컨설팅 가능 대상 코드',
    CNSTNT_RQSTDT        DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '신청일',
    ACT_BEGIN_DE         DATETIME                           COMMENT '활동시작일자',
    ACT_END_DE           DATETIME                           COMMENT '활동종료일자',
    REGISTER             VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR               VARCHAR(20)                        COMMENT '수정자',
    UPDDE                DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (CNSTNT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='컨설턴트 정보';

-- 컨설턴트 신청 이력
CREATE TABLE IF NOT EXISTS TH_CNSTNT_REQST_HIST (
    CNSTNT_SN        BIGINT      NOT NULL              COMMENT '컨설턴트 순번',
    REQST_HIST_SN    BIGINT      NOT NULL              COMMENT '신청 이력 순번',
    REQST_STTUS_CODE VARCHAR(5)  NOT NULL              COMMENT '신청 상태 코드',
    REGISTER         VARCHAR(20) NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    PRIMARY KEY (CNSTNT_SN, REQST_HIST_SN),
    CONSTRAINT fk_cnstnt_reqst_hist_info FOREIGN KEY (CNSTNT_SN) REFERENCES TN_CNSTNT_INFO (CNSTNT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='컨설턴트 신청 이력';

-- 컨설팅 일정 정보
CREATE TABLE IF NOT EXISTS TN_CNSL_SCHDUL_INFO (
    CNSTNT_SN BIGINT      NOT NULL              COMMENT '컨설턴트 순번',
    RESVE_SN  BIGINT      NOT NULL              COMMENT '예약 순번',
    RESVE_DE  DATETIME    NOT NULL              COMMENT '예약 일시',
    RESVE_TIME INT        NOT NULL              COMMENT '예약 시간',
    REGISTER  VARCHAR(20) NOT NULL              COMMENT '등록자',
    RGSDE     DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR    VARCHAR(20)                       COMMENT '수정자',
    UPDDE     DATETIME    DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (CNSTNT_SN, RESVE_SN),
    CONSTRAINT fk_cnsl_schdul_cnstnt FOREIGN KEY (CNSTNT_SN) REFERENCES TN_CNSTNT_INFO (CNSTNT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='컨설팅 일정 정보';

-- 컨설팅 신청 정보
CREATE TABLE IF NOT EXISTS TN_CNSL_REQST_INFO (
    CNSL_SN            BIGINT       NOT NULL              COMMENT '컨설팅 순번',
    USER_SN            BIGINT       NOT NULL              COMMENT '사용자 순번',
    CNSL_MTHD_CODE     VARCHAR(5)   NOT NULL              COMMENT '컨설팅 방식 코드',
    CNSL_TOPIC_CODE    VARCHAR(5)   NOT NULL              COMMENT '컨설팅 주제 코드',
    CNSL_RLM_CODE      VARCHAR(5)   NOT NULL              COMMENT '컨설팅 분야 코드',
    RESUME_OTHBC_AT    VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '이력서 공개 여부',
    CNSL_REQST_CN      TEXT                               COMMENT '컨설팅 신청 내용(원본 VARCHAR2(4000))',
    CNSTNT_SN          BIGINT       NOT NULL              COMMENT '컨설턴트 순번',
    RESVE_SN           BIGINT                             COMMENT '예약 순번',
    CANCL_RESN         VARCHAR(500)                       COMMENT '취소 사유',
    DCSN_AT            VARCHAR(1)                         COMMENT '확정 여부',
    CNSL_RQSTDT        DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '컨설팅 신청일',
    CNSL_COMPT_AT      VARCHAR(1)   DEFAULT 'N'           COMMENT '컨설팅 완료 여부',
    CNSL_COMPT_DE      DATETIME                           COMMENT '컨설팅 완료 일자',
    CNSL_RSLT_CN       TEXT                               COMMENT '컨설팅 결과 내용(원본 VARCHAR2(4000))',
    CNSL_REQST_FILE_ID BIGINT                             COMMENT '파일 ID',
    CNSL_RSLT_FILE_ID  BIGINT                             COMMENT '결과 파일 ID',
    REGISTER           VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE              DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR             VARCHAR(20)                        COMMENT '수정자',
    UPDDE              DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    INDVDLINFO_AGRE_AT VARCHAR(1)                         COMMENT '개인정보동의여부',
    PRIMARY KEY (CNSL_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='컨설팅 신청 정보';

-- 역량 진단 (※ 우리 sys_competency_diagnosis 와 이름 동일 — 성격은 다름(레거시=진단 폼 정의))
CREATE TABLE IF NOT EXISTS TN_ABILITY_DGNSS (
    EXMNTIN_YEAR    VARCHAR(4)   NOT NULL              COMMENT '진단 년도',
    EXMNTIN_NM      VARCHAR(200) NOT NULL              COMMENT '진단 명',
    EXMNTIN_TOP_SCR INT          DEFAULT 5             COMMENT '진단 최고 점수',
    USE_AT          VARCHAR(1)   DEFAULT 'Y'           COMMENT '사용여부',
    DELETE_AT       CHAR(1)      DEFAULT 'N'           COMMENT '삭제 여부',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR          VARCHAR(20)                        COMMENT '수정자',
    UPDDE           DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXMNTIN_YEAR)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='역량 진단';

-- 역량 진단 문항
CREATE TABLE IF NOT EXISTS TN_ABILITY_DGNSS_QESITM (
    EXMNTIN_YEAR     VARCHAR(4)    NOT NULL              COMMENT '진단 년도',
    QESITM_SN        BIGINT        NOT NULL              COMMENT '문항 순번',
    UPPER_QESITM_SN  BIGINT                              COMMENT '상위 문항 순번',
    QESITM_CN        VARCHAR(1000) NOT NULL              COMMENT '문항 내용',
    CAREER_STEP_CODE VARCHAR(5)    NOT NULL              COMMENT '경력 단계 코드',
    DFN_CN           VARCHAR(1000)                       COMMENT '정의 내용',
    DELETE_AT        CHAR(1)       DEFAULT 'N'           COMMENT '삭제 여부',
    REGISTER         VARCHAR(20)   NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR           VARCHAR(20)                         COMMENT '수정자',
    UPDDE            DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXMNTIN_YEAR, QESITM_SN),
    CONSTRAINT fk_ability_dgnss_qesitm_dgnss FOREIGN KEY (EXMNTIN_YEAR) REFERENCES TN_ABILITY_DGNSS (EXMNTIN_YEAR)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='역량 진단 문항';

-- 역량 진단 내용
--   ※ FK QESITM_SN → TN_ABILITY_DGNSS_QESITM 이나 부모 PK가 복합(EXMNTIN_YEAR, QESITM_SN)
--      이라 단일컬럼 매칭 불가 → FK 보류(확인 필요).
CREATE TABLE IF NOT EXISTS TN_ABILITY_DGNSS_CN (
    QESITM_SN         BIGINT       NOT NULL              COMMENT '문항 순번',
    EXMNTIN_RSLT_CODE VARCHAR(5)   NOT NULL              COMMENT '진단 결과 코드',
    RSLT_SN           BIGINT       NOT NULL              COMMENT '결과 순번',
    EXMNTIN_RSLT_CN   TEXT                               COMMENT '진단 결과 내용(원본 VARCHAR2(4000))',
    DELETE_AT         CHAR(1)      DEFAULT 'N'           COMMENT '삭제 여부',
    REGISTER          VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE             DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR            VARCHAR(20)                        COMMENT '수정자',
    UPDDE             DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (QESITM_SN, EXMNTIN_RSLT_CODE, RSLT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='역량 진단 내용';

-- 역량 진단 답변  (※ 위와 동일 사유로 FK 보류)
CREATE TABLE IF NOT EXISTS TN_ABILITY_DGNSS_ANSWER (
    QESITM_SN  BIGINT       NOT NULL              COMMENT '문항 순번',
    ANSWER_SN  BIGINT       NOT NULL              COMMENT '답변 순번',
    ANSWER_CN  TEXT                               COMMENT '답변내용(원본 VARCHAR2(4000))',
    ANSWER_SCR INT                                COMMENT '답변 점수',
    DELETE_AT  CHAR(1)      DEFAULT 'N'           COMMENT '삭제 여부',
    REGISTER   VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE      DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR     VARCHAR(20)                        COMMENT '수정자',
    UPDDE      DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (QESITM_SN, ANSWER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='역량 진단 답변';

-- 역량 진단 참여자
CREATE TABLE IF NOT EXISTS TN_ABILITY_DGNSS_PRTCPNT (
    EXMNTIN_SN       BIGINT      NOT NULL              COMMENT '진단 순번',
    USER_SN          BIGINT      NOT NULL              COMMENT '사용자 순번',
    DTY_CODE         VARCHAR(5)  NOT NULL              COMMENT '직무 코드',
    CAREER_STEP_CODE VARCHAR(5)  NOT NULL              COMMENT '경력 단계 코드',
    EXMNTIN_COMPT_AT VARCHAR(1)  DEFAULT 'N'           COMMENT '진단 완료 여부',
    REGISTER         VARCHAR(20) NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR           VARCHAR(20)                       COMMENT '수정자',
    UPDDE            DATETIME    DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXMNTIN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='역량 진단 참여자';

-- 역량 진단 참여 이력
CREATE TABLE IF NOT EXISTS TH_ABILITY_DGNSS_PARTCPTN_HIST (
    EXMNTIN_SN              BIGINT      NOT NULL              COMMENT '진단 순번',
    EXMNTIN_HIST_SN         BIGINT      NOT NULL              COMMENT '진단 이력 순번',
    EXMNTIN_PRGRS_STTUS_CODE VARCHAR(5) NOT NULL              COMMENT '진단 진행 상태 코드',
    REGISTER               VARCHAR(20) NOT NULL              COMMENT '등록자',
    RGSDE                  DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    PRIMARY KEY (EXMNTIN_SN, EXMNTIN_HIST_SN),
    CONSTRAINT fk_ability_dgnss_partcptn_hist_prtcpnt FOREIGN KEY (EXMNTIN_SN) REFERENCES TN_ABILITY_DGNSS_PRTCPNT (EXMNTIN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='역량 진단 참여 이력';

-- 역량 진단 참여 내역  (※ QESITM_SN→TN_ABILITY_DGNSS_QESITM 은 부모 복합PK라 보류)
CREATE TABLE IF NOT EXISTS TN_ABILITY_DGNSS_PARTCPTN_DTLS (
    EXMNTIN_SN        BIGINT      NOT NULL              COMMENT '진단 순번',
    QESITM_SN         BIGINT      NOT NULL              COMMENT '문항 순번',
    CHOISE_ANSWER_SN  BIGINT      NOT NULL              COMMENT '선택 답변 순번',
    CHOISE_ANSWER_SCR INT         NOT NULL              COMMENT '선택 답변 점수',
    REGISTER          VARCHAR(20) NOT NULL              COMMENT '등록자',
    RGSDE             DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR            VARCHAR(20)                       COMMENT '수정자',
    UPDDE             DATETIME    DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXMNTIN_SN, QESITM_SN),
    CONSTRAINT fk_ability_dgnss_dtls_prtcpnt FOREIGN KEY (EXMNTIN_SN) REFERENCES TN_ABILITY_DGNSS_PRTCPNT (EXMNTIN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='역량 진단 참여 내역';

-- 역량 진단 참여 결과  (※ QESITM_SN→TN_ABILITY_DGNSS_QESITM 은 부모 복합PK라 보류)
CREATE TABLE IF NOT EXISTS TN_ABILITY_DGNSS_RESULT (
    EXMNTIN_SN        BIGINT       NOT NULL              COMMENT '진단 순번',
    QESITM_SN         BIGINT       NOT NULL              COMMENT '문항 순번',
    EXMNTIN_RSLT_CODE VARCHAR(5)   NOT NULL              COMMENT '진단 결과 코드',
    AVRG_SCR          DECIMAL(3,2) NOT NULL              COMMENT '평균 점수',
    REGISTER          VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE             DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR            VARCHAR(20)                        COMMENT '수정자',
    UPDDE             DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (EXMNTIN_SN, QESITM_SN),
    CONSTRAINT fk_ability_dgnss_result_prtcpnt FOREIGN KEY (EXMNTIN_SN) REFERENCES TN_ABILITY_DGNSS_PRTCPNT (EXMNTIN_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='역량 진단 참여 결과';

-- 강사 정보
CREATE TABLE IF NOT EXISTS TN_INSTRCTR_INFO (
    INSTRCTR_SN     BIGINT      NOT NULL              COMMENT '강사 순번',
    USER_SN         BIGINT      NOT NULL              COMMENT '사용자 순번',
    INSTRCTR_RQSTDT DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '강사 신청일',
    ACT_BEGIN_DE    DATETIME                          COMMENT '활동시작일자',
    ACT_END_DE      DATETIME                          COMMENT '활동종료일자',
    RGSDE           DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER        VARCHAR(20) NOT NULL              COMMENT '등록자',
    UPDDE           DATETIME    DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR          VARCHAR(20)                       COMMENT '수정자',
    PRIMARY KEY (INSTRCTR_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='강사 정보';

-- 강사 신청 이력
CREATE TABLE IF NOT EXISTS TH_INSTRCTR_REQST_HIST (
    INSTRCTR_SN      BIGINT      NOT NULL              COMMENT '강사 순번',
    REQST_HIST_SN    BIGINT      NOT NULL              COMMENT '신청 이력 순번',
    REQST_STTUS_CODE VARCHAR(5)  NOT NULL              COMMENT '신청 상태 코드',
    RGSDE            DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER         VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (INSTRCTR_SN, REQST_HIST_SN),
    CONSTRAINT fk_instrctr_reqst_hist_info FOREIGN KEY (INSTRCTR_SN) REFERENCES TN_INSTRCTR_INFO (INSTRCTR_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='강사 신청 이력';

-- 교육신청인대상
CREATE TABLE IF NOT EXISTS TN_EDC_APPLCNT_TRGET (
    EDC_BSNS_SN       BIGINT      NOT NULL              COMMENT '교육 사업 순번',
    USER_SN           BIGINT      NOT NULL              COMMENT '사용자 순번',
    EDC_REQST_TRGT_SE VARCHAR(5)  NOT NULL              COMMENT '교육 신청 대상 구분',
    RGSDE             DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER          VARCHAR(20) NOT NULL              COMMENT '등록자',
    UPDDE             DATETIME    DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR            VARCHAR(20)                       COMMENT '수정자',
    PRIMARY KEY (EDC_BSNS_SN, USER_SN, EDC_REQST_TRGT_SE),
    CONSTRAINT fk_edc_applcnt_trget_applcnt FOREIGN KEY (EDC_BSNS_SN, USER_SN) REFERENCES TN_EDC_APPLCNT (EDC_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='교육신청인대상';

-- 일자리신청기관채용정보
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_EMPMN (
    WRK_BSNS_SN          BIGINT       NOT NULL              COMMENT '일자리사업순번',
    BIZRNO               VARCHAR(12)  NOT NULL              COMMENT '사업자번호',
    DTL_SN               INT          NOT NULL              COMMENT '상세순번',
    EMPMN_AT             VARCHAR(1)   DEFAULT 'N'           COMMENT '채용여부',
    EMPMN_PRERNG_DE      DATETIME                           COMMENT '채용예정일자',
    EMPMN_PRERNG_USER_NM VARCHAR(50)                        COMMENT '채용예정사용자명',
    LAST_DGRI_NM         VARCHAR(100)                       COMMENT '최종학위명',
    EMPLYM_TY_CODE       VARCHAR(5)                         COMMENT '고용유형코드',
    ANSLRY_AM            BIGINT                             COMMENT '연봉금액',
    RGSDE                DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER             VARCHAR(20)  NOT NULL              COMMENT '등록자',
    PRIMARY KEY (WRK_BSNS_SN, BIZRNO, DTL_SN),
    CONSTRAINT fk_wrk_reqinst_empmn_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관채용정보';

-- 일자리신청기관담당자  (활용/인사/행정 담당자 정보)
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_CHARGER (
    WRK_BSNS_SN                    BIGINT       NOT NULL    COMMENT '일자리사업순번',
    BIZRNO                         VARCHAR(12)  NOT NULL    COMMENT '사업자번호',
    PRCUSE_CHARGER_NM              VARCHAR(50)              COMMENT '활용담당자명',
    PRCUSE_CHARGER_DEPT_NM         VARCHAR(50)              COMMENT '활용담당자부서명',
    PRCUSE_CHARGER_OFCPS_NM        VARCHAR(50)              COMMENT '활용담당자직위명',
    PRCUSE_CHARGER_MAJOR_NM        VARCHAR(50)              COMMENT '활용담당자전공명',
    PRCUSE_CHARGER_SEXDSTN_SE_CODE VARCHAR(5)               COMMENT '활용담당자성별구분',
    PRCUSE_CHARGER_BRTHDY          VARCHAR(8)               COMMENT '활용담당자생년월일',
    PRCUSE_CHARGER_MBTLNUM         VARCHAR(13)              COMMENT '활용담당자휴대폰번호',
    PRCUSE_CHARGER_TELNO           VARCHAR(13)              COMMENT '활용담당자전화번호',
    PRCUSE_CHARGER_EMAIL           VARCHAR(50)              COMMENT '활용담당자이메일',
    PRCUSE_CHARGER_FAX             VARCHAR(13)              COMMENT '활용담당자FAX',
    HR_CHARGER_NM                  VARCHAR(50)              COMMENT '인사담당자명',
    HR_CHARGER_DEPT_NM             VARCHAR(50)              COMMENT '인사담당자부서명',
    HR_CHARGER_OFCPS_NM            VARCHAR(50)              COMMENT '인사담당자직위명',
    HR_CHARGER_MAJOR_NM            VARCHAR(50)              COMMENT '인사담당자전공명',
    HR_CHARGER_SEXDSTN_SE_CODE     VARCHAR(5)               COMMENT '인사담당자성별구분코드',
    HR_CHARGER_BRTHDY              VARCHAR(8)               COMMENT '인사담당자생년월일',
    HR_CHARGER_MBTLNUM             VARCHAR(13)              COMMENT '인사담당자휴대폰번호',
    HR_CHARGER_TELNO               VARCHAR(13)              COMMENT '인사담당자전화번호',
    HR_CHARGER_EMAIL               VARCHAR(50)              COMMENT '인사담당자이메일',
    HR_CHARGER_FAX                 VARCHAR(13)              COMMENT '인사담당자FAX',
    ADST_CHARGER_NM                VARCHAR(50)              COMMENT '행정담당자명',
    ADST_CHARGER_DEPT_NM           VARCHAR(50)              COMMENT '행정담당자부서명',
    ADST_CHARGER_OFCPS_NM          VARCHAR(50)              COMMENT '행정담당자직위명',
    ADST_CHARGER_MAJOR_NM          VARCHAR(50)              COMMENT '행정담당자전공명',
    ADST_CHARGER_SEXDSTN_SE_CODE   VARCHAR(5)               COMMENT '행정담당자성별구분코드',
    ADST_CHARGER_BRTHDY            VARCHAR(8)               COMMENT '행정담당자생년월일',
    ADST_CHARGER_MBTLNUM           VARCHAR(13)              COMMENT '행정담당자휴대폰번호',
    ADST_CHARGER_TELNO             VARCHAR(13)              COMMENT '행정담당자전화번호',
    ADST_CHARGER_EMAIL             VARCHAR(50)              COMMENT '행정담당자이메일',
    ADST_CHARGER_FAX               VARCHAR(13)              COMMENT '행정담당자FAX',
    RGSDE                          DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                       VARCHAR(20)  NOT NULL    COMMENT '등록자',
    UPDDE                          DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                         VARCHAR(20)  NOT NULL    COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN),
    CONSTRAINT fk_wrk_reqinst_charger_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관담당자';

-- 연구 사업
CREATE TABLE IF NOT EXISTS TN_RSRCH_BSNS (
    RSRCH_BSNS_SN                 BIGINT       NOT NULL              COMMENT '연구 사업 순번',
    RSRCH_BSNS_YEAR               VARCHAR(4)   NOT NULL              COMMENT '연구 사업 년도',
    RSRCH_BSNS_SE_CODE            VARCHAR(5)   NOT NULL              COMMENT '연구 사업 구분 코드',
    TEAMMB_SE_CODE                VARCHAR(5)                         COMMENT '팀원 구분 코드',
    RSRCH_BSNS_NM                 VARCHAR(50)  NOT NULL              COMMENT '연구사업명',
    RSRCH_BSNS_BEGIN_DE           DATETIME     NOT NULL              COMMENT '연구 사업 시작 일자',
    RSRCH_BSNS_END_DE             DATETIME     NOT NULL              COMMENT '연구 사업 종료 일자',
    RSCHT_RCRIT_BEGIN_DT          DATETIME     NOT NULL              COMMENT '연구팀 모집 시작 일시',
    RSCHT_RCRIT_END_DT            DATETIME     NOT NULL              COMMENT '연구팀 모집 종료 일시',
    RSCHT_RCRIT_PEPSPLMN_BEGIN_DT DATETIME     NOT NULL              COMMENT '연구팀 모집 서류보완 시작 일시',
    RSCHT_RCRIT_PEPSPLMN_END_DT   DATETIME     NOT NULL              COMMENT '연구팀 모집 서류보완 종료 일시',
    PRM_MHST_MTCHG_BEGIN_DT       DATETIME                          COMMENT '1차 중고등생 매칭 시작 일시',
    PRM_MHST_MTCHG_END_DT         DATETIME                          COMMENT '1차 중고등생 매칭 종료 일시',
    SCD_MHST_MTCHG_BEGIN_DT       DATETIME                          COMMENT '2차 중고등생 매칭 시작 일시',
    SCD_MHST_MTCHG_END_DT         DATETIME                          COMMENT '2차 중고등생 매칭 종료 일시',
    TRD_MHST_MTCHG_BEGIN_DT       DATETIME                          COMMENT '3차 중고등생 매칭 시작 일시',
    TRD_MHST_MTCHG_END_DT         DATETIME                          COMMENT '3차 중고등생 매칭 종료 일시',
    NTCN_SN                       BIGINT                            COMMENT '알림순번',
    NTCE_AT                       VARCHAR(1)   NOT NULL DEFAULT 'Y' COMMENT '게시여부',
    RGSDE                         DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                      VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                         DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                        VARCHAR(20)                       COMMENT '수정자',
    RCVFVER_HELP_MATTER           VARCHAR(200)                      COMMENT '수혜자 협조 사항(이전데이터)',
    INDVDLINFO                    VARCHAR(600)                      COMMENT '개인정보수집내용(이전데이터)',
    PRIMARY KEY (RSRCH_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='연구 사업';

-- 연구 진행 이력
CREATE TABLE IF NOT EXISTS TH_RSRCH_PROGRS_HIST (
    RSRCH_BSNS_SN              BIGINT      NOT NULL              COMMENT '연구 사업 순번',
    RSRCH_BSNS_PRGRS_STTUS_CODE VARCHAR(5) NOT NULL              COMMENT '연구 사업 진행 상태 코드',
    RGSDE                     DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                  VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (RSRCH_BSNS_SN, RSRCH_BSNS_PRGRS_STTUS_CODE),
    CONSTRAINT fk_rsrch_progrs_hist_bsns FOREIGN KEY (RSRCH_BSNS_SN) REFERENCES TN_RSRCH_BSNS (RSRCH_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='연구 진행 이력';

-- 연구팀
CREATE TABLE IF NOT EXISTS TN_RSCHT (
    RSCHT_SN                 BIGINT        NOT NULL              COMMENT '연구팀 순번',
    RSRCH_TASK_NM            VARCHAR(50)   NOT NULL              COMMENT '연구과제명',
    RSRCH_BEGIN_DE           DATETIME      NOT NULL              COMMENT '연구시작일자',
    RSRCH_END_DE             DATETIME      NOT NULL              COMMENT '연구종료일자',
    REQST_RLM_CODE           VARCHAR(5)    NOT NULL              COMMENT '신청 분야 코드',
    PRCUSE_INTRST_RLM_CODE   VARCHAR(5)    NOT NULL              COMMENT '활용 관심 분야 코드',
    ETC_CN                   VARCHAR(50)                         COMMENT '기타내용',
    AREA_CODE                VARCHAR(5)    NOT NULL              COMMENT '지역 코드',
    SIGNGU_NM                VARCHAR(100)                        COMMENT '시군구명',
    RSRCH_SUMRY              VARCHAR(2000)                       COMMENT '연구 요약',
    RSRCH_PURPS_SUMRY        VARCHAR(2000)                       COMMENT '연구 목적 요약',
    RSRCH_CN_SUMRY           VARCHAR(2000)                       COMMENT '연구 내용 요약',
    EXPC_EFFECT_SUMRY        VARCHAR(2000)                       COMMENT '기대 효과 요약',
    RSRCH_RSPNBER_AGRE_AT    VARCHAR(1)    DEFAULT 'N'           COMMENT '신청 책임자 동의 여부',
    RSRCH_CCH_PROFSR_AGRE_AT VARCHAR(1)    DEFAULT 'N'           COMMENT '신청 지도 교수 동의 여부',
    RSRCH_RSLT_SUMRY_CN      TEXT                                COMMENT '연구 결과 요약 내용(원본 VARCHAR2(4000))',
    RSRCH_RSLT_FILE_ID       BIGINT                              COMMENT '연구 결과 파일 ID',
    REQSTDOC_PRSNTN_AT       VARCHAR(1)    DEFAULT 'N'           COMMENT '신청서 제출 여부',
    RSRCH_INTRCN             VARCHAR(2000) NOT NULL              COMMENT '연구 소개',
    TEAM_NO                  VARCHAR(10)                         COMMENT '팀 번호',
    RGSDE                    DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                 VARCHAR(20)   NOT NULL              COMMENT '등록자',
    UPDDE                    DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                   VARCHAR(20)                         COMMENT '수정자',
    PRIMARY KEY (RSCHT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='연구팀';

-- 연구팀 신청 내용
CREATE TABLE IF NOT EXISTS TN_RSCHT_REQST_CN (
    RSCHT_SN                 BIGINT        NOT NULL              COMMENT '연구팀 순번',
    RSRCH_PURPS              VARCHAR(2000)                       COMMENT '연구 목적',
    SOCTY_QUES_RSRCH_AT      VARCHAR(1)                          COMMENT '사회 문제 연구 여부',
    RSRCH_ORIGINALLITY       TEXT                                COMMENT '연구 독창성(원본 VARCHAR2(4000))',
    PRECDNG_RSRCH            TEXT                                COMMENT '선행 연구(원본 VARCHAR2(4000))',
    RSRCH_CN                 TEXT                                COMMENT '연구 내용(원본 VARCHAR2(4000))',
    RSRCH_RSLT_PRCUSE_METHOD TEXT                                COMMENT '연구 결과 활용 방안(원본 VARCHAR2(4000))',
    RSRCH_PRTN_PROVS_METHOD  TEXT                                COMMENT '연구 추진 대비 방안(원본 VARCHAR2(4000))',
    COLST_MNTORNG_PRTN_PLAN  TEXT                                COMMENT '대학생 멘토링 추진 계획(원본 VARCHAR2(4000))',
    MHST_MNTORNG_PRTN_PLAN   TEXT                                COMMENT '중고등생 멘토링 추진 계획(원본 VARCHAR2(4000))',
    INDUST_MNTOR_NM          VARCHAR(200)                        COMMENT '산업 멘토 명',
    INDUST_MNTOR_PSITN_NM    VARCHAR(200)                        COMMENT '산업 멘토 소속 명',
    INDUST_MNTOR_ROLE        TEXT                                COMMENT '산업 멘토 역할(원본 VARCHAR2(4000))',
    BDGTPR_FILE_ID           BIGINT                              COMMENT '제출 서류 파일 ID',
    ETC_ATCHMNFL_ID          BIGINT                              COMMENT '기타 첨부파일 ID',
    PD_ISE_RDDUC_PLAN        TEXT                                COMMENT '기간 내 성과도출 계획(원본 VARCHAR2(4000))',
    PD_AFTER_RDDUC_PLAN      TEXT                                COMMENT '기간 이후 성과도출 계획(원본 VARCHAR2(4000))',
    RGSDE                    DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                 VARCHAR(20)   NOT NULL              COMMENT '등록자',
    UPDDE                    DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                   VARCHAR(20)                         COMMENT '수정자',
    PRIMARY KEY (RSCHT_SN),
    CONSTRAINT fk_rscht_reqst_cn_rscht FOREIGN KEY (RSCHT_SN) REFERENCES TN_RSCHT (RSCHT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='연구팀 신청 내용';

-- 연구팀 진행 이력
CREATE TABLE IF NOT EXISTS TH_RSCHT_PROGRS_HIST (
    RSCHT_SN               BIGINT        NOT NULL              COMMENT '연구팀 순번',
    PRGRS_HIST_SN          BIGINT        NOT NULL              COMMENT '진행 이력 순번',
    RSCHT_PRGRS_STTUS_CODE VARCHAR(5)    NOT NULL              COMMENT '연구팀 진행 상태 코드',
    RSCHT_PRGRS_RSLT_CODE  VARCHAR(5)                          COMMENT '연구팀 진행 결과 코드',
    SPLEMNT_CN             VARCHAR(1000)                       COMMENT '보완 내용',
    RGSDE                  DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER               VARCHAR(20)   NOT NULL              COMMENT '등록자',
    PRIMARY KEY (RSCHT_SN, PRGRS_HIST_SN),
    CONSTRAINT fk_rscht_progrs_hist_rscht FOREIGN KEY (RSCHT_SN) REFERENCES TN_RSCHT (RSCHT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='연구팀 진행 이력';

-- 연구 신청자
CREATE TABLE IF NOT EXISTS TN_RSRCH_APPLCNT (
    RSRCH_BSNS_SN              BIGINT        NOT NULL              COMMENT '연구 사업 순번',
    USER_SN                   BIGINT        NOT NULL              COMMENT '사용자 순번',
    WISET_ID                  VARCHAR(20)   NOT NULL              COMMENT 'WISET ID',
    PSITN_RSCHT_SN            BIGINT                              COMMENT '소속 연구팀 순번',
    APLCNT_SE_CODE            VARCHAR(5)    NOT NULL              COMMENT '신청자 구분 코드',
    PSITN_SCHUL_NM            VARCHAR(200)                        COMMENT '소속 학교 명',
    MAJOR_NM                  VARCHAR(50)                         COMMENT '전공명',
    GRADE                     INT                                 COMMENT '학년',
    DGRI_CRSE_SE_CODE         VARCHAR(5)                          COMMENT '학위 과정 구분 코드',
    SEMSTR                    INT                                 COMMENT '학기',
    PARTCPTNRT                DECIMAL(5,2)                        COMMENT '참여율',
    TEAM_ISE_ROLE            VARCHAR(2000)                       COMMENT '팀 내 역할',
    INDVDL_INFO_PRCUSE_AGRE_AT VARCHAR(1)   DEFAULT 'N'          COMMENT '개인 정보 활용 동의 여부',
    REQST_RPRSNTV_ID          VARCHAR(20)                         COMMENT '신청 대표자 ID',
    BAN                       INT                                 COMMENT '반',
    SPORT_SYNC_CN             TEXT                                COMMENT '지원동기내용(원본 VARCHAR2(4000))',
    RSRCH_PARTCPTN_PLAN       TEXT                                COMMENT '연구 참여 계획(원본 VARCHAR2(4000))',
    HOPE_1RNK_NM              VARCHAR(100)                        COMMENT '희망1순위명',
    HOPE_2RNK_NM              VARCHAR(100)                        COMMENT '희망2순위명',
    HOPE_3RNK_NM              VARCHAR(100)                        COMMENT '희망3순위명',
    TEAM_PARTCPTN_AT          VARCHAR(1)                          COMMENT '팀 참여 여부',
    SCHUL_HED_CNFRMN_FILE_ID  BIGINT                              COMMENT '학교 장 확인서 파일 ID',
    ABTNT_RECOMEND_FILE_ID    BIGINT                              COMMENT '교사 추천 파일 ID',
    PRTCTOR_WRTCNS_FILE_ID    BIGINT                              COMMENT '보호자 동의서 파일 ID',
    RGSDE                     DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                  VARCHAR(20)   NOT NULL              COMMENT '등록자',
    UPDDE                     DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                    VARCHAR(20)                         COMMENT '수정자',
    APLCNT_NM                 VARCHAR(100)                        COMMENT '신청자 명(이전데이터)',
    APLCNT_ID                 VARCHAR(100)                        COMMENT '신청자 ID(이전데이터)',
    APLCNT_MBTLNUM            VARCHAR(20)                         COMMENT '신청자 휴대폰번호(이전데이터)',
    APLCNT_EMAIL              VARCHAR(100)                        COMMENT '신청자 이메일(이전데이터)',
    APLCNT_BRTHDY             VARCHAR(8)                          COMMENT '신청자 생년월일(이전데이터)',
    APLCNT_MAJOR              VARCHAR(100)                        COMMENT '신청자 전공(이전데이터)',
    PROFSR_NM                 VARCHAR(100)                        COMMENT '교수 명(이전데이터)',
    PROFSR_MAJOR              VARCHAR(100)                        COMMENT '교수 전공(이전데이터)',
    PROFSR_PSITN              VARCHAR(100)                        COMMENT '교수 소속(이전데이터)',
    PROFSR_EMAIL              VARCHAR(100)                        COMMENT '교수 이메일(이전데이터)',
    PROFSR_TELNO              VARCHAR(20)                         COMMENT '교수 연락처(이전데이터)',
    ACDINCP_EMAIL             VARCHAR(100)                        COMMENT '산학협력 이메일(이전데이터)',
    ACDINCP_MBTLNUM           VARCHAR(20)                         COMMENT '산학협력 휴대전화(이전데이터)',
    ACDINCP_ADRES             VARCHAR(200)                        COMMENT '산학협력 주소(이전데이터)',
    ACDINCP_DTL_ADRES         VARCHAR(200)                        COMMENT '산학협력 상세 주소(이전데이터)',
    ACDINCP_ZIP               VARCHAR(10)                         COMMENT '산학협력 우편번호(이전데이터)',
    HOPE_1RNK_TEAM_NO         VARCHAR(100)                        COMMENT '희망 1순위 팀 번호(이전데이터)',
    HOPE_2RNK_TEAM_NO         VARCHAR(100)                        COMMENT '희망 2순위 팀 번호(이전데이터)',
    HOPE_3RNK_TEAM_NO         VARCHAR(100)                        COMMENT '희망 3순위 팀 번호(이전데이터)',
    PROFSR_ADRES              VARCHAR(200)                        COMMENT '교수 주소(이전데이터)',
    PROFSR_DTL_ADRES          VARCHAR(200)                        COMMENT '교수 상세 주소(이전데이터)',
    PROFSR_ZIP                VARCHAR(10)                         COMMENT '교수 우편번호(이전데이터)',
    ETC_ATCHMNFL_ID           BIGINT                              COMMENT '기타 첨부파일 ID(이전데이터)',
    PRIMARY KEY (RSRCH_BSNS_SN, USER_SN),
    CONSTRAINT fk_rsrch_applcnt_bsns FOREIGN KEY (RSRCH_BSNS_SN) REFERENCES TN_RSRCH_BSNS (RSRCH_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='연구 신청자';

-- 연구 신청 이력
CREATE TABLE IF NOT EXISTS TH_RSRCH_REQST_HIST (
    RSRCH_BSNS_SN          BIGINT        NOT NULL              COMMENT '연구 사업 순번',
    USER_SN                BIGINT        NOT NULL              COMMENT '사용자 순번',
    PRGRS_HIST_SN          BIGINT        NOT NULL              COMMENT '진행 이력 순번',
    REQST_PRGRS_STTUS_CODE VARCHAR(5)    NOT NULL              COMMENT '신청 진행 상태 코드',
    REQST_PRGRS_RSLT_CODE  VARCHAR(5)                          COMMENT '신청 진행 결과 코드',
    SPLEMNT_CN             VARCHAR(1000)                       COMMENT '보완 내용',
    RGSDE                  DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER               VARCHAR(20)   NOT NULL              COMMENT '등록자',
    PRIMARY KEY (RSRCH_BSNS_SN, USER_SN, PRGRS_HIST_SN),
    CONSTRAINT fk_rsrch_reqst_hist_applcnt FOREIGN KEY (RSRCH_BSNS_SN, USER_SN) REFERENCES TN_RSRCH_APPLCNT (RSRCH_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='연구 신청 이력';

-- 일자리신청인첨부파일
CREATE TABLE IF NOT EXISTS TN_WRK_APPLCNT_ATCH_FILE (
    WRK_BSNS_SN         BIGINT      NOT NULL              COMMENT '일자리사업순번',
    USER_SN             BIGINT      NOT NULL              COMMENT '사용자순번',
    PRSNTN_FILE_SE_CODE VARCHAR(5)  NOT NULL              COMMENT '제출파일구분코드',
    FILE_ID             BIGINT      NOT NULL              COMMENT '파일ID',
    RGSDE               DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER            VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (WRK_BSNS_SN, USER_SN, PRSNTN_FILE_SE_CODE, FILE_ID),
    CONSTRAINT fk_wrk_applcnt_atch_file_applcnt FOREIGN KEY (WRK_BSNS_SN, USER_SN) REFERENCES TN_WRK_APPLCNT (WRK_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청인첨부파일';

-- 일자리신청기관첨부파일
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_ATCH_FILE (
    WRK_BSNS_SN         BIGINT      NOT NULL              COMMENT '일자리사업순번',
    BIZRNO              VARCHAR(12) NOT NULL              COMMENT '사업자번호',
    PRSNTN_FILE_SE_CODE VARCHAR(5)  NOT NULL              COMMENT '제출파일구분코드',
    FILE_ID             BIGINT      NOT NULL              COMMENT '파일ID',
    RGSDE               DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER            VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (WRK_BSNS_SN, BIZRNO, PRSNTN_FILE_SE_CODE, FILE_ID),
    CONSTRAINT fk_wrk_reqinst_atch_file_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관첨부파일';

-- 온라인멘토신청이력
CREATE TABLE IF NOT EXISTS TH_ONLINE_MNTOR_REQST_HST (
    USER_SN          BIGINT      NOT NULL              COMMENT '사용자순번',
    REQST_HIST_SN    BIGINT      NOT NULL              COMMENT '신청이력순번',
    REQST_STTUS_CODE VARCHAR(5)  NOT NULL              COMMENT '진행상태코드',
    REQST_RSLT_CN    TEXT                              COMMENT '신청결과내용(원본 VARCHAR2(4000))',
    RGSDE            DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER         VARCHAR(20) NOT NULL              COMMENT '등록자',
    UPDDE            DATETIME    DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR           VARCHAR(20)                       COMMENT '수정자',
    PRIMARY KEY (USER_SN, REQST_HIST_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='온라인멘토신청이력';

-- FAQ 정보
CREATE TABLE IF NOT EXISTS TN_FAQ_INFO (
    FAQ_SEQ   BIGINT        NOT NULL AUTO_INCREMENT COMMENT 'FAQ 순번',
    CTGRY     VARCHAR(100)                          COMMENT '카테고리',
    BSNS_NM   VARCHAR(100)                          COMMENT '사업명',
    CHRG_TEAN VARCHAR(100)                          COMMENT '담당팀',
    FAQ_SJ    VARCHAR(1000)                         COMMENT '제목',
    ANSWER_CN LONGTEXT                              COMMENT '답변 내용(원본 CLOB)',
    RGSDE     DATETIME      DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER  VARCHAR(20)                           COMMENT '등록자',
    UPDDE     DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR    VARCHAR(20)                           COMMENT '수정자',
    PRIMARY KEY (FAQ_SEQ)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='FAQ 정보';

-- 과학기술직무보기
CREATE TABLE IF NOT EXISTS TN_SCNCE_TCHNLGY_DTY (
    DTY_SEQ   BIGINT        NOT NULL AUTO_INCREMENT COMMENT '과학기술직무 순번',
    DTY_SE    VARCHAR(100)                          COMMENT '구분(ONET/WORKNET)',
    DTY_CODE  VARCHAR(50)                           COMMENT '직무 코드',
    DTY_GROUP VARCHAR(50)                           COMMENT '직무 그룹(TOP/SUB)',
    DTY_NM    VARCHAR(2000)                         COMMENT '직무 명',
    RGSDE     DATETIME      DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER  VARCHAR(20)                           COMMENT '등록자',
    UPDDE     DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR    VARCHAR(20)                           COMMENT '수정자',
    PRIMARY KEY (DTY_SEQ)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='과학기술직무보기';

-- 과학기술직무보기 상세
CREATE TABLE IF NOT EXISTS TN_SCNCE_TCHNLGY_DTLS (
    DTLS_SEQ   BIGINT       NOT NULL AUTO_INCREMENT COMMENT '과학기술직무보기 상세 순번',
    DTY_SE     VARCHAR(100)                         COMMENT '구분(ONET/WORKNET)',
    DTY_CODE   VARCHAR(50)                          COMMENT '직무 코드',
    JBGP       VARCHAR(500)                         COMMENT '직군',
    DEPT       TEXT                                 COMMENT '부서(원본 VARCHAR(4000))',
    TASK       TEXT                                 COMMENT '업무(원본 VARCHAR(4000))',
    KNWLDG     TEXT                                 COMMENT '지식(원본 VARCHAR(4000))',
    SKLL       TEXT                                 COMMENT '기능(원본 VARCHAR(4000))',
    ABLTY      TEXT                                 COMMENT '능력(원본 VARCHAR(4000))',
    PRSNL      TEXT                                 COMMENT '성격(원본 VARCHAR(4000))',
    TCHNLGY    TEXT                                 COMMENT '기술(원본 VARCHAR(4000))',
    EDC        VARCHAR(500)                         COMMENT '교육',
    WAGE       VARCHAR(500)                         COMMENT '기본 임금',
    RELATE_DTY TEXT                                 COMMENT '관련직업(원본 VARCHAR(4000))',
    RGSDE      DATETIME      DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER   VARCHAR(20)                          COMMENT '등록자',
    UPDDE      DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR     VARCHAR(20)                          COMMENT '수정자',
    PRIMARY KEY (DTLS_SEQ)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='과학기술직무보기 상세';

-- 과학기술직무보기 관계  (※ 원본 테이블명에 TN_ 접두사 없음 — 그대로 유지)
CREATE TABLE IF NOT EXISTS SCNCE_TCHNLGY_RELATE (
    RELATE_SEQ  BIGINT       NOT NULL AUTO_INCREMENT COMMENT '과학기술직무 관계 순번',
    RELATE_CODE VARCHAR(100)                         COMMENT '관계 코드',
    DTY_CODE    VARCHAR(50)                          COMMENT '직무 코드',
    DTY_SE      VARCHAR(100)                         COMMENT '구분(ONET/WORKNET)',
    RGSDE       DATETIME      DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER    VARCHAR(20)                          COMMENT '등록자',
    UPDDE       DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR      VARCHAR(20)                          COMMENT '수정자',
    PRIMARY KEY (RELATE_SEQ)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='과학기술직무보기 관계';

-- 개인회원 전문가 정보
CREATE TABLE IF NOT EXISTS TN_INDVDL_EXPERT (
    USER_SN              BIGINT        NOT NULL    COMMENT '사용자 순번',
    MNTOR_AT             VARCHAR(1)                COMMENT '멘토 여부',
    MNTOR_CN             VARCHAR(1000)             COMMENT '멘토 내용',
    MNTOR_WRC            VARCHAR(50)               COMMENT '멘토 직장',
    MNTOR_DEPT           VARCHAR(50)               COMMENT '멘토 부서',
    MNTOR_OFCPS          VARCHAR(50)               COMMENT '멘토 직위',
    MNTOR_RLM            VARCHAR(200)              COMMENT '멘토 분야',
    MNTOR_ACT_CAREER     VARCHAR(1000)             COMMENT '멘토 활동 경력',
    MNTOR_MAIN_CAREER    VARCHAR(1000)             COMMENT '멘토 주요 경력',
    INSTRCTR_AT          VARCHAR(1)                COMMENT '강사 여부',
    INSTRCTR_CN          VARCHAR(1000)             COMMENT '강사 내용',
    CNSTNT_AT            VARCHAR(1)                COMMENT '컨설턴트 여부',
    CNSL_POSBL_TRGT_CODE VARCHAR(5)                COMMENT '컨설팅 가능 대상 코드',
    CNSL_TOPIC_CODE      VARCHAR(5)                COMMENT '컨설팅 주제 코드',
    CNSL_RLM_CODE        VARCHAR(5)                COMMENT '컨설팅 분야 코드',
    CNSL_SPCLTY_RLM      TEXT                      COMMENT '컨설팅 전문 분야(원본 VARCHAR2(4000))',
    RULE_MODL_AT         VARCHAR(1)                COMMENT '롤 모델 여부',
    JUDGE_AT             VARCHAR(1)                COMMENT '심사위원 여부',
    CNSUT_AT             VARCHAR(1)                COMMENT '자문 여부',
    POSTN_RECOMEND_AT    VARCHAR(1)                COMMENT '포지션 추천 여부',
    RWARD_RECOMEND_AT    VARCHAR(1)                COMMENT '포상 추천 여부',
    REGISTER             VARCHAR(20)   NOT NULL    COMMENT '등록자',
    RGSDE                DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR               VARCHAR(20)   NOT NULL    COMMENT '수정자',
    UPDDE                DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    MNTOR_AGREE          VARCHAR(1)                COMMENT '멘토 동의',
    MNTOR_AGREE2         VARCHAR(1)                COMMENT '멘토 동의2',
    MNTOR_AGREE3         VARCHAR(1)                COMMENT '멘토 동의3',
    INSTRCTR_AGREE       VARCHAR(1)                COMMENT '강사 동의',
    INSTRCTR_AGREE2      VARCHAR(1)                COMMENT '강사 동의2',
    INSTRCTR_AGREE3      VARCHAR(1)                COMMENT '강사 동의3',
    INSTRCTR_AGREE4      VARCHAR(1)                COMMENT '강사 동의4',
    CNSTNT_AGREE         VARCHAR(1)                COMMENT '컨설턴트 동의',
    CNSTNT_AGREE2        VARCHAR(1)                COMMENT '컨설턴트 동의2',
    CNSTNT_AGREE3        VARCHAR(1)                COMMENT '컨설턴트 동의3',
    LECTURE_OFFICE       VARCHAR(1000)             COMMENT '주요강의처',
    LECTURE_AREA         VARCHAR(1000)             COMMENT '강의 가능 지역',
    LECTURE_REALM        VARCHAR(1000)             COMMENT '강의 활동 가능 분야',
    LECTURE_CAREER       VARCHAR(1000)             COMMENT '주요 강의 경력',
    LECTURE_FILE_ID      VARCHAR(1000)             COMMENT '강의계획서 파일 ID',
    PRIMARY KEY (USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='개인회원 전문가 정보';

-- 연구 추진 일정
CREATE TABLE IF NOT EXISTS TN_RSCHT_PRTN_SCHDUL (
    RSCHT_SN              BIGINT       NOT NULL              COMMENT '연구팀 순번',
    RSRCH_SCHDUL_SN       BIGINT       NOT NULL              COMMENT '연구 일정 순번',
    RSRCH_SCHDUL_BEGIN_DE DATETIME                          COMMENT '연구 일정 시작 일자',
    RSRCH_SCHDUL_END_DE   DATETIME                          COMMENT '연구 일정 종료 일자',
    RSRCH_SCHDUL_CN       VARCHAR(300)                      COMMENT '연구 일정 내용',
    REGISTER              VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE                 DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR                VARCHAR(20)                        COMMENT '수정자',
    UPDDE                 DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (RSCHT_SN, RSRCH_SCHDUL_SN),
    CONSTRAINT fk_rscht_prtn_schdul_rscht FOREIGN KEY (RSCHT_SN) REFERENCES TN_RSCHT (RSCHT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='연구 추진 일정';

-- 멘토링사업
CREATE TABLE IF NOT EXISTS TN_MNTORNG_BSNS (
    MNTORNG_BSNS_SN        BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    MNTORNG_BSNS_SE_CODE   VARCHAR(5)   NOT NULL              COMMENT '멘토링사업구분코드',
    MNTORNG_BSNS_NM        VARCHAR(200) NOT NULL              COMMENT '멘토링사업명',
    NTCE_AT                VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '게시여부',
    BSNS_BEGIN_DE          DATETIME                           COMMENT '사업시작일자',
    BSNS_END_DE            DATETIME                           COMMENT '사업종료일자',
    MNTEE_RCEPT_BEGIN_DT   DATETIME                           COMMENT '멘티접수시작일시',
    MNTEE_RCEPT_END_DT     DATETIME                           COMMENT '멘티접수종료일시',
    MNTEE_PEPSPLMN_BEGIN_DT DATETIME                          COMMENT '멘티서류보완시작일시',
    MNTEE_PEPSPLMN_END_DT  DATETIME                           COMMENT '멘티서류보완종료일시',
    NTCN_SN                BIGINT                             COMMENT '알림순번',
    RGSDE                  DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER               VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                  DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                 VARCHAR(20)  NOT NULL              COMMENT '수정자',
    RCEPT_NTCN_SNDNG_AT    VARCHAR(1)                         COMMENT '접수알림발송여부',
    PRIMARY KEY (MNTORNG_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='멘토링사업';

-- 멘토링사업진행이력
CREATE TABLE IF NOT EXISTS TH_MNTORNG_BSNS_PRGRS_HST (
    MNTORNG_BSNS_SN               BIGINT      NOT NULL              COMMENT '멘토링사업순번',
    MNTORNG_BSNS_PRGRS_STTUS_CODE VARCHAR(5) NOT NULL              COMMENT '멘토링사업진행상태코드',
    RGSDE                         DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                      VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (MNTORNG_BSNS_SN, MNTORNG_BSNS_PRGRS_STTUS_CODE),
    CONSTRAINT fk_mntorng_bsns_prgrs_hst_bsns FOREIGN KEY (MNTORNG_BSNS_SN) REFERENCES TN_MNTORNG_BSNS (MNTORNG_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='멘토링사업진행이력';

-- 글로벌멘토링신청  (※ FK (MNTORNG_BSNS_SN, USER_SN)→TN_MNTORNG_APPLCNT 미수신 → FK 보류)
CREATE TABLE IF NOT EXISTS TN_MNTORNG_GLOBAL_REQST (
    MNTORNG_BSNS_SN         BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    USER_SN                 BIGINT       NOT NULL              COMMENT '사용자순번',
    LAST_DGRI_SE_CODE       VARCHAR(5)                         COMMENT '최종학위구분코드',
    MAJOR_NM                VARCHAR(50)                        COMMENT '전공명',
    GRDTN_PRERNG_YEAR       VARCHAR(4)                         COMMENT '졸업예정년도',
    GRDTN_AT                VARCHAR(1)                         COMMENT '졸업여부',
    GRADE                   INT                                COMMENT '학년',
    SEMSTR                  INT                                COMMENT '학년학기명',
    PSITN_NM                VARCHAR(200)                       COMMENT '소속 명',
    MNTORNG_HOPE_RLM_SE_CODE VARCHAR(5)                        COMMENT '멘토링희망분야구분코드',
    MNTORNG_HOPE_RLM_ETC_NM VARCHAR(200)                       COMMENT '멘토링희망분야기타명',
    ENGL_ABILITY_CN         VARCHAR(200)                       COMMENT '영어역량내용',
    ENGL_TEST_SCRE_CN       VARCHAR(200)                       COMMENT '영어시험성적내용',
    ENGL_EDC_CN             VARCHAR(200) DEFAULT 'N'           COMMENT '영어교육내용',
    RGSDE                   DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                   DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                  VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (MNTORNG_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='글로벌멘토링신청';

-- 멘토링신청인
CREATE TABLE IF NOT EXISTS TN_MNTORNG_APPLCNT (
    MNTORNG_BSNS_SN    BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    USER_SN            BIGINT       NOT NULL              COMMENT '사용자순번',
    RESDNC_AREA_CODE   VARCHAR(5)                         COMMENT '거주지지역코드',
    PRGRS_STTUS_CODE   VARCHAR(5)                         COMMENT '진행상태코드',
    PRGRS_RSLT_CN      TEXT                               COMMENT '진행결과내용(원본 VARCHAR2(4000))',
    EVAL_RSLT_CODE     VARCHAR(5)                         COMMENT '평가결과코드',
    FILE_ID            BIGINT                             COMMENT '파일ID',
    REQSTDOC_AGRE_AT   VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '신청서동의여부',
    INDVDLINFO_AGRE_SN BIGINT                             COMMENT '개인정보동의순번',
    REQST_DE           DATETIME                           COMMENT '신청일자',
    COMPL_AT           VARCHAR(1)   NOT NULL DEFAULT 'N'  COMMENT '수료여부',
    RGSDE              DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER           VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE              DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR             VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (MNTORNG_BSNS_SN, USER_SN),
    CONSTRAINT fk_mntorng_applcnt_bsns FOREIGN KEY (MNTORNG_BSNS_SN) REFERENCES TN_MNTORNG_BSNS (MNTORNG_BSNS_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='멘토링신청인';

-- (보류했던 FK 연결) TN_MNTORNG_GLOBAL_REQST → TN_MNTORNG_APPLCNT
ALTER TABLE TN_MNTORNG_GLOBAL_REQST
    ADD CONSTRAINT fk_mntorng_global_reqst_applcnt
    FOREIGN KEY (MNTORNG_BSNS_SN, USER_SN) REFERENCES TN_MNTORNG_APPLCNT (MNTORNG_BSNS_SN, USER_SN);

-- 재직자멘토링신청
CREATE TABLE IF NOT EXISTS TN_MNTORNG_HFFC_REQST (
    MNTORNG_BSNS_SN   BIGINT       NOT NULL              COMMENT '멘토링사업순번',
    USER_SN           BIGINT       NOT NULL              COMMENT '사용자순번',
    LAST_DGRI_SE_CODE VARCHAR(5)                         COMMENT '최종학위구분코드',
    MAJOR_NM          VARCHAR(50)                        COMMENT '전공명',
