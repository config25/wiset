    XPORT_AM               BIGINT        DEFAULT 0            COMMENT '수출금액',
    BSN_PRFT_AM            BIGINT        DEFAULT 0            COMMENT '영업이익금액',
    THSTRM_NTPF_AM         BIGINT        DEFAULT 0            COMMENT '당기순이익금액',
    BSN_PRFT_PT            INT           DEFAULT 0            COMMENT '영업이익백분율',
    INVT_AM                BIGINT        DEFAULT 0            COMMENT '투자금액',
