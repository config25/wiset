    UPDUSR          VARCHAR(20)                       COMMENT '수정자',
    UPDDE           DATETIME    DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    PRIMARY KEY (USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='14세미만 보호자';

-- 멘토링멘토
CREATE TABLE IF NOT EXISTS TN_MNTORNG_MNTOR (
    MNTOR_USER_ID     VARCHAR(20)   NOT NULL              COMMENT '멘토사용자ID',
    USER_NM           VARCHAR(20)                         COMMENT '사용자명',
    BRTHDY            VARCHAR(8)                          COMMENT '생년월일',
    SEXDSTN_SE_CODE   VARCHAR(5)                          COMMENT '성별구분코드',
    MBTLNUM           VARCHAR(13)                         COMMENT '휴대폰번호',
    EMAIL             VARCHAR(100)                        COMMENT '이메일',
    MNTOR_WRC         VARCHAR(50)                         COMMENT '멘토직장',
    MNTOR_DEPT        VARCHAR(50)                         COMMENT '멘토부서',
    MNTOR_OFCPS       VARCHAR(50)                         COMMENT '멘토직위',
    MNTOR_CN          VARCHAR(1000)                       COMMENT '멘토내용',
    MNTOR_RLM         VARCHAR(200)                        COMMENT '멘토분야',
    MNTOR_ACT_CAREER  VARCHAR(1000)                       COMMENT '멘토활동경력',
    MNTOR_MAIN_CAREER VARCHAR(1000)                       COMMENT '멘토주요경력',
    ONLINE_MNTORNG_AT VARCHAR(1)                          COMMENT '온라인멘토링여부',
    USER_TY_CODE      VARCHAR(5)                          COMMENT '사용자유형코드',
    FILE_ID           BIGINT                              COMMENT '파일ID',
    RM_CN             TEXT                                COMMENT '비고내용(원본 VARCHAR2(4000))',
    RGSDE             DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER          VARCHAR(20)   NOT NULL              COMMENT '등록자',
    UPDDE             DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR            VARCHAR(20)   NOT NULL              COMMENT '수정자',
    PRIMARY KEY (MNTOR_USER_ID)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='멘토링멘토';

-- 멘토링인터뷰답변
CREATE TABLE IF NOT EXISTS TN_MNTORNG_INTV_ANSWER (
    MNTORNG_BSNS_SN BIGINT      NOT NULL              COMMENT '멘토링사업순번',
    DTL_SN          INT         NOT NULL              COMMENT '상세순번',
    USER_SN         BIGINT      NOT NULL              COMMENT '사용자순번',
    ANSWER_CN       TEXT                              COMMENT '답변내용(원본 VARCHAR2(4000))',
    RGSDE           DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER        VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (MNTORNG_BSNS_SN, DTL_SN, USER_SN),
    CONSTRAINT fk_mntorng_intv_answer_iem FOREIGN KEY (MNTORNG_BSNS_SN, DTL_SN) REFERENCES TN_MNTORNG_INTV_IEM (MNTORNG_BSNS_SN, DTL_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='멘토링인터뷰답변';

-- 학술 활동 사업
CREATE TABLE IF NOT EXISTS TN_SCHLSHP_ACT_BSNS (
    SCHLSHP_ACT_SN                BIGINT       NOT NULL              COMMENT '학술 활동 사업 순번',
    SCHLSHP_ACT_YEAR              VARCHAR(4)   NOT NULL              COMMENT '학술 활동 사업 년도',
    SCHLSHP_ACT_SE_CODE           VARCHAR(5)   NOT NULL              COMMENT '학술 활동 구분 코드',
    SCHLSHP_ACT_BSNS_NM           VARCHAR(100) NOT NULL              COMMENT '학술 활동 사업 명',
    SCHLSHP_ACT_BEGIN_DE          DATETIME     NOT NULL              COMMENT '학술 활동 시작 일자',
    SCHLSHP_ACT_END_DE            DATETIME     NOT NULL              COMMENT '학술 활동 종료 일자',
    SCHLSHP_ACT_REQST_BEGIN_DT    DATETIME     NOT NULL              COMMENT '학술 활동 신청 시작 일시',
    SCHLSHP_ACT_REQST_END_DT      DATETIME     NOT NULL              COMMENT '학술 활동 신청 종료 일시',
    SCHLSHP_ACT_PEPSPLMN_BEGIN_DT DATETIME     NOT NULL              COMMENT '학술 활동 서류보완 시작 일시',
    SCHLSHP_ACT_PEPSPLMN_END_DT   DATETIME     NOT NULL              COMMENT '학술 활동 서류보완 종료 일시',
    BSNS_DC_DE                    DATETIME                           COMMENT '사업 설명 일자',
    RCVFVER_IFMGTHDCS_DE          DATETIME                           COMMENT '수혜자 간담회 일자',
    NTCN_SN                       BIGINT                             COMMENT '알림순번',
    NTCE_AT                       VARCHAR(1)   NOT NULL DEFAULT 'Y'  COMMENT '게시여부',
    RGSDE                         DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                      VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                         DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                        VARCHAR(20)                        COMMENT '수정자',
    PARTCPTN_INSTT                VARCHAR(300)                       COMMENT '참여 기관(이전데이터)',
    RCVFVER_HELP_MATTER           VARCHAR(200)                       COMMENT '수혜자 협조 사항(이전데이터)',
    PRIMARY KEY (SCHLSHP_ACT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='학술 활동 사업';

-- 학술 활동 진행 이력
CREATE TABLE IF NOT EXISTS TH_SCHLSHP_ACT_PROGRS_HIST (
    SCHLSHP_ACT_SN              BIGINT      NOT NULL              COMMENT '학술 활동 사업 순번',
    SCHLSHP_ACT_PRGRS_STTUS_CODE VARCHAR(5) NOT NULL              COMMENT '학술 활동 진행 상태 코드',
    RGSDE                      DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                   VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (SCHLSHP_ACT_SN, SCHLSHP_ACT_PRGRS_STTUS_CODE),
    CONSTRAINT fk_schlshp_act_progrs_hist_bsns FOREIGN KEY (SCHLSHP_ACT_SN) REFERENCES TN_SCHLSHP_ACT_BSNS (SCHLSHP_ACT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='학술 활동 진행 이력';

-- 학술 활동 신청자
CREATE TABLE IF NOT EXISTS TN_SCHLSHP_ACT_APPLCNT (
    SCHLSHP_ACT_SN             BIGINT        NOT NULL              COMMENT '학술 활동 사업 순번',
    USER_SN                    BIGINT        NOT NULL              COMMENT '사용자 순번',
    RCEPT_NO                   VARCHAR(20)   NOT NULL              COMMENT '접수 번호',
    SPORT_RLM_SE_CODE          VARCHAR(5)    NOT NULL              COMMENT '지원 분야 구분 코드',
    APLCNT_SE_CODE             VARCHAR(5)    NOT NULL              COMMENT '신청자 구분 코드',
    LRSTY_PARTCPTN_AT          VARCHAR(1)                          COMMENT '학회 참여 여부',
    DEPT_NM                    VARCHAR(50)                         COMMENT '부서 명',
    CLSF_NM                    VARCHAR(100)                        COMMENT '직급명',
    MAJOR_NM                   VARCHAR(50)   NOT NULL              COMMENT '전공명',
    LAST_DGRI_NM               VARCHAR(100)  NOT NULL              COMMENT '최종학위명',
    TASK_RSPNBER_NM            VARCHAR(100)                        COMMENT '과제 책임자 명',
    TASK_RSPNBER_PSITN         VARCHAR(200)                        COMMENT '과제 책임자 소속',
    TASK_RSPNBER_MAJOR         VARCHAR(100)                        COMMENT '과제 책임자 전공',
    TASK_RSPNBER_TELNO         VARCHAR(13)                         COMMENT '과제 책임자 전화번호',
    PSITN_INSTT_NM             VARCHAR(100)  NOT NULL              COMMENT '소속기관명',
    RPRSNTV_NM                 VARCHAR(50)                         COMMENT '대표자명',
    INSTT_ADRES                VARCHAR(100)                        COMMENT '기관 주소',
    LRSTY_NM                   VARCHAR(200)  NOT NULL              COMMENT '학회 명',
    PRESNATN_SJ                VARCHAR(500)                        COMMENT '발표 제목',
    THESIS_AUTHR               VARCHAR(200)                        COMMENT '논문 저자',
    HMPG_URL                   VARCHAR(50)                         COMMENT '홈페이지URL',
    BSRP_NATION_NM             VARCHAR(50)   NOT NULL              COMMENT '출장 국가 명',
    BSRP_CTY_NM                VARCHAR(100)  NOT NULL              COMMENT '출장 도시 명',
    BSRP_BEGIN_DE              DATETIME      NOT NULL              COMMENT '출장 시작 일자',
    BSRP_END_DE                DATETIME      NOT NULL              COMMENT '출장 종료 일자',
    SPORT_REQST_CT             BIGINT        NOT NULL              COMMENT '지원 신청 비용',
    PARTCPTN_AGRE_AT           VARCHAR(1)    NOT NULL DEFAULT 'N'  COMMENT '참여 동의 여부',
    INDVDL_INFO_PRCUSE_AGRE_AT VARCHAR(1)    NOT NULL DEFAULT 'N'  COMMENT '개인 정보 활용 동의 여부',
    REQST_AGRE_AT              VARCHAR(1)    NOT NULL DEFAULT 'N'  COMMENT '신청 동의 여부',
    INDVDL_INFO_COLCT_AGRE_AT  VARCHAR(1)                          COMMENT '개인 정보 수집 동의',
    PARTCPTN_PURPS             TEXT                                COMMENT '참여 목적(원본 VARCHAR2(4000))',
    SUMRY_CN                   TEXT                                COMMENT '요약 내용(원본 VARCHAR2(4000))',
    RSRCH_CN                   TEXT                                COMMENT '연구 내용(원본 VARCHAR2(4000))',
    PRCUSE_PLAN_CN             TEXT                                COMMENT '활용계획내용(원본 VARCHAR2(4000))',
    ABSN_RESN                  TEXT                                COMMENT '불참 사유(원본 VARCHAR2(4000))',
    REQST_OFLDC_FILE_ID        BIGINT                              COMMENT '신청 공문서 파일 ID',
    MAIN_ACHV_FILE_ID          BIGINT                              COMMENT '주요 업적 파일 ID',
    SPRMNY_REQST_DTSTMN_FILE_ID BIGINT                             COMMENT '지원금 신청 내역서 파일 ID',
    PLDG_AGRE_AT               VARCHAR(1)    DEFAULT 'N'           COMMENT '서약서 동의 여부',
    REQSTDOC_PRSNTN_AT         VARCHAR(1)    DEFAULT 'N'           COMMENT '신청서 제출 여부',
    RSRCH_RSLT_CN              TEXT                                COMMENT '연구결과내용(원본 VARCHAR2(4000))',
    RSRCH_RSLT_FILE_ID         BIGINT                              COMMENT '연구 결과 파일 ID',
    LOCPLC                     VARCHAR(1000)                       COMMENT '소재지',
    RGSDE                      DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                   VARCHAR(20)   NOT NULL              COMMENT '등록자',
    UPDDE                      DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                     VARCHAR(20)                         COMMENT '수정자',
    NAME                       VARCHAR(200)                        COMMENT '이름(이전데이터)',
    WISET_ID                   VARCHAR(20)                         COMMENT 'WISET ID(이전데이터)',
    MBTLNUM                    VARCHAR(13)                         COMMENT '휴대폰번호(이전데이터)',
    EMAIL                      VARCHAR(100)                        COMMENT '이메일(이전데이터)',
    BRTHDY                     VARCHAR(8)                          COMMENT '생년월일(이전데이터)',
    RESDNC                     VARCHAR(100)                        COMMENT '거주지(이전데이터)',
    LAST_DGRI_SCHUL            VARCHAR(100)                        COMMENT '최종 학위 학교(이전데이터)',
    MAJOR_SE                   VARCHAR(4)                          COMMENT '전공 구분(이전데이터)',
    AUTHR                      VARCHAR(10)                         COMMENT '저자(이전데이터)',
    PRIMARY KEY (SCHLSHP_ACT_SN, USER_SN),
    CONSTRAINT fk_schlshp_act_applcnt_bsns FOREIGN KEY (SCHLSHP_ACT_SN) REFERENCES TN_SCHLSHP_ACT_BSNS (SCHLSHP_ACT_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='학술 활동 신청자';

-- 학술 활동 신청 이력
CREATE TABLE IF NOT EXISTS TH_SCHLSHP_ACT_REQST_HIST (
    SCHLSHP_ACT_SN         BIGINT      NOT NULL              COMMENT '학술 활동 사업 순번',
    USER_SN                BIGINT      NOT NULL              COMMENT '사용자 순번',
    PRGRS_HIST_SN          BIGINT      NOT NULL              COMMENT '진행 이력 순번',
    REQST_PRGRS_STTUS_CODE VARCHAR(5)  NOT NULL              COMMENT '신청 진행 상태 코드',
    REQST_PRGRS_RSLT_CODE  VARCHAR(5)                        COMMENT '신청 진행 결과 코드',
    RGSDE                  DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER               VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (SCHLSHP_ACT_SN, USER_SN, PRGRS_HIST_SN),
    CONSTRAINT fk_schlshp_act_reqst_hist_applcnt FOREIGN KEY (SCHLSHP_ACT_SN, USER_SN) REFERENCES TN_SCHLSHP_ACT_APPLCNT (SCHLSHP_ACT_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='학술 활동 신청 이력';

-- 학술 활동 수혜 경험
CREATE TABLE IF NOT EXISTS TN_SCHLSHP_ACT_RCVFVR_EXPRNC (
    SCHLSHP_ACT_SN   BIGINT       NOT NULL              COMMENT '학술 활동 사업 순번',
    USER_SN          BIGINT       NOT NULL              COMMENT '사용자 순번',
    RCVFVR_EXPRNC_SN BIGINT       NOT NULL              COMMENT '수혜 경험 순번',
    PARTCPTN_YEAR    VARCHAR(4)   NOT NULL              COMMENT '참여 년도',
    PARTCPTN_BSNS_NM VARCHAR(200) NOT NULL              COMMENT '참여 사업 명',
    RCVFVR_AM        BIGINT       NOT NULL              COMMENT '수혜 금액',
    RM_CN            TEXT                               COMMENT '비고내용(원본 VARCHAR2(4000))',
    RGSDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER         VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE            DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR           VARCHAR(20)                        COMMENT '수정자',
    PRIMARY KEY (SCHLSHP_ACT_SN, USER_SN, RCVFVR_EXPRNC_SN),
    CONSTRAINT fk_schlshp_rcvfvr_exprnc_applcnt FOREIGN KEY (SCHLSHP_ACT_SN, USER_SN) REFERENCES TN_SCHLSHP_ACT_APPLCNT (SCHLSHP_ACT_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='학술 활동 수혜 경험';

-- 학술 활동 계획 일정
CREATE TABLE IF NOT EXISTS TN_SCHLSHP_ACT_PLAN_SCHDUL (
    SCHLSHP_ACT_SN  BIGINT        NOT NULL              COMMENT '학술 활동 사업 순번',
    USER_SN         BIGINT        NOT NULL              COMMENT '사용자 순번',
    SCHDUL_SN       BIGINT        NOT NULL              COMMENT '일정 순번',
    SCHDUL_BEGIN_DE DATETIME      NOT NULL              COMMENT '일정 시작 일자',
    SCHDUL_END_DE   DATETIME      NOT NULL              COMMENT '일정 종료 일자',
    SCHDUL_CN       VARCHAR(1000) NOT NULL              COMMENT '일정 내용',
    RGSDE           DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER        VARCHAR(20)   NOT NULL              COMMENT '등록자',
    UPDDE           DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR          VARCHAR(20)                         COMMENT '수정자',
    PRIMARY KEY (SCHLSHP_ACT_SN, USER_SN, SCHDUL_SN),
    CONSTRAINT fk_schlshp_plan_schdul_applcnt FOREIGN KEY (SCHLSHP_ACT_SN, USER_SN) REFERENCES TN_SCHLSHP_ACT_APPLCNT (SCHLSHP_ACT_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='학술 활동 계획 일정';

-- 학술 활동 신청자 학력
CREATE TABLE IF NOT EXISTS TN_SCHLSHP_ACT_APPLCNT_ACDMCR (
    SCHLSHP_ACT_SN BIGINT       NOT NULL              COMMENT '학술 활동 사업 순번',
    USER_SN        BIGINT       NOT NULL              COMMENT '사용자 순번',
    ACDMCR_SN      BIGINT       NOT NULL              COMMENT '학력 순번',
    CCH_PROFSR_NM  VARCHAR(100) NOT NULL              COMMENT '지도 교수 명',
    ACQS_NATION_NM VARCHAR(200) NOT NULL              COMMENT '취득 국가',
    RGSDE          DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER       VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE          DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR         VARCHAR(20)                        COMMENT '수정자',
    PRIMARY KEY (SCHLSHP_ACT_SN, USER_SN, ACDMCR_SN),
    CONSTRAINT fk_schlshp_applcnt_acdmcr_applcnt FOREIGN KEY (SCHLSHP_ACT_SN, USER_SN) REFERENCES TN_SCHLSHP_ACT_APPLCNT (SCHLSHP_ACT_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='학술 활동 신청자 학력';

-- 취업탐색매칭결과
--   ※ FK MNTORNG_BSNS_SN → TN_EMPSRCH_REQSTTM 이나 부모 PK가 3컬럼(…, USER_ID 포함)이라 매칭 불가 → FK 보류.
CREATE TABLE IF NOT EXISTS TN_EMPSRCH_MTCHG_RSLT (
    MNTORNG_BSNS_SN BIGINT      NOT NULL              COMMENT '멘토링사업순번',
    USER_ID         VARCHAR(20) NOT NULL              COMMENT '사용자ID',
    USER_SN         BIGINT      NOT NULL              COMMENT '사용자순번',
    RGSDE           DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER        VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (MNTORNG_BSNS_SN, USER_ID, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='취업탐색매칭결과';

-- 개인 관심 기업
CREATE TABLE IF NOT EXISTS TN_INDVDL_INTRST_INSTT (
    INDVDL_USER_SN BIGINT      NOT NULL              COMMENT '개인 사용자 순번',
    INSTT_USER_SN  BIGINT      NOT NULL              COMMENT '기관 사용자 순번',
    RGSDE          DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER       VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (INDVDL_USER_SN, INSTT_USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='개인 관심 기업';

-- 개인 공고 스크랩
CREATE TABLE IF NOT EXISTS TN_INDVDL_PBLANC_SCRAP (
    INDVDL_USER_SN BIGINT       NOT NULL              COMMENT '개인 사용자 순번',
    INSTT_USER_SN  BIGINT       NOT NULL              COMMENT '기관 사용자 순번',
    PBLANC_SN      BIGINT       NOT NULL              COMMENT '공고 순번',
    PBLANC_NM      VARCHAR(200)                       COMMENT '공고 명',
    RGSDE          DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER       VARCHAR(20)  NOT NULL              COMMENT '등록자',
    PRIMARY KEY (INDVDL_USER_SN, INSTT_USER_SN, PBLANC_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='개인 공고 스크랩';

-- 기관 인재 스크랩
CREATE TABLE IF NOT EXISTS TN_INSTT_ABLMAN_SCRAP (
    INSTT_USER_SN  BIGINT      NOT NULL              COMMENT '기관 사용자 순번',
    INDVDL_USER_SN BIGINT      NOT NULL              COMMENT '개인 사용자 순번',
    RGSDE          DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER       VARCHAR(20) NOT NULL              COMMENT '등록자',
    PRIMARY KEY (INSTT_USER_SN, INDVDL_USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='기관 인재 스크랩';

-- 입사 지원 제의
CREATE TABLE IF NOT EXISTS TN_ECNY_SPORT_SUGEST (
    ECNY_SUGEST_SN          BIGINT        NOT NULL              COMMENT '입사 제의 순번',
    INSTT_USER_SN           BIGINT        NOT NULL              COMMENT '기관 사용자 순번',
    INDVDL_USER_SN          BIGINT        NOT NULL              COMMENT '개인 사용자 순번',
    PBLANC_SN               BIGINT        NOT NULL              COMMENT '공고 순번',
    CHARGER_SN              BIGINT        NOT NULL              COMMENT '담당자 순번',
    RCRIT_RLM               VARCHAR(1000)                       COMMENT '모집 분야',
    CHRG_JOB                VARCHAR(1000)                       COMMENT '담당 업무',
    SPORT_MTH               VARCHAR(1000)                       COMMENT '지원 방법',
    REQUST_MSSAGE           TEXT                                COMMENT '요청 메시지(원본 VARCHAR2(4000))',
    HOPE_WORK_AREA          VARCHAR(5)                          COMMENT '희망 근무 지역',
    PRSNTN_PAPERS_NM        VARCHAR(200)                        COMMENT '제출서류명',
    FILE_ID                 BIGINT                              COMMENT '파일 ID',
    RECPTN_CNFIRM_AT        VARCHAR(1)    DEFAULT 'N'           COMMENT '수신 확인 여부',
    INDVDL_SUGEST_DELETE_AT VARCHAR(1)    DEFAULT 'N'           COMMENT '개인 제의 삭제 여부',
    RECPTN_CNFIRM_DE        DATETIME                            COMMENT '수신 확인 일자',
    RGSDE                   DATETIME      NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                VARCHAR(20)   NOT NULL              COMMENT '등록자',
    UPDDE                   DATETIME      DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                  VARCHAR(20)                         COMMENT '수정자',
    PRIMARY KEY (ECNY_SUGEST_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='입사 지원 제의';

-- 일자리신청인경력
CREATE TABLE IF NOT EXISTS TN_WRK_APPLCNT_CAREER (
    WRK_BSNS_SN     BIGINT       NOT NULL              COMMENT '일자리사업순번',
    USER_SN         BIGINT       NOT NULL              COMMENT '사용자순번',
    DTL_SN          INT          NOT NULL              COMMENT '상세순번',
    CAREER_INSTT_NM VARCHAR(100)                       COMMENT '경력기관명',
    DEPT_NM         VARCHAR(50)                        COMMENT '부서명',
    CLSF_NM         VARCHAR(100)                       COMMENT '직급명',
    CAREER_CN       TEXT                               COMMENT '경력내용(원본 VARCHAR2(4000))',
    CAREER_BEGIN_DE VARCHAR(10)                        COMMENT '경력시작일자',
    CAREER_END_DE   VARCHAR(12)                        COMMENT '경력종료일자',
    RETIRE_RESN_CN  VARCHAR(100)                       COMMENT '퇴직사유내용',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    PRIMARY KEY (WRK_BSNS_SN, USER_SN, DTL_SN),
    CONSTRAINT fk_wrk_applcnt_career_applcnt FOREIGN KEY (WRK_BSNS_SN, USER_SN) REFERENCES TN_WRK_APPLCNT (WRK_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청인경력';

-- 일자리신청인학력
CREATE TABLE IF NOT EXISTS TN_WRK_APPLCNT_ACDMCR (
    WRK_BSNS_SN     BIGINT       NOT NULL              COMMENT '일자리사업순번',
    USER_SN         BIGINT       NOT NULL              COMMENT '사용자순번',
    DTL_SN          INT          NOT NULL              COMMENT '상세순번',
    SCHUL_NM        VARCHAR(100)                       COMMENT '학교명',
    ACDMCR_BEGIN_DE VARCHAR(12)                        COMMENT '학력시작일자',
    ACDMCR_END_DE   VARCHAR(12)                        COMMENT '학력종료일자',
    ACDMCR_SE_CODE  VARCHAR(5)                         COMMENT '학력구분코드',
    MAJOR_NM        VARCHAR(50)                        COMMENT '전공명',
    ADIMAJOR        VARCHAR(100)                       COMMENT '부전공',
    AREA_NM         VARCHAR(50)                        COMMENT '지역 명',
    GRDTN_SE_CODE   VARCHAR(5)                         COMMENT '졸업구분코드',
    REGISTER        VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE           DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    PRIMARY KEY (WRK_BSNS_SN, USER_SN, DTL_SN),
    CONSTRAINT fk_wrk_applcnt_acdmcr_applcnt FOREIGN KEY (WRK_BSNS_SN, USER_SN) REFERENCES TN_WRK_APPLCNT (WRK_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청인학력';

-- 일자리신청인어학
CREATE TABLE IF NOT EXISTS TN_WRK_APPLCNT_LSTCS (
    WRK_BSNS_SN  BIGINT       NOT NULL              COMMENT '일자리사업순번',
    USER_SN      BIGINT       NOT NULL              COMMENT '사용자순번',
    DTL_SN       INT          NOT NULL              COMMENT '상세순번',
    FGGG_NM      VARCHAR(5)                         COMMENT '외국어명',
    FGGG_TEST_NM VARCHAR(100)                       COMMENT '외국어시험명',
    ACQS_DE      DATETIME                           COMMENT '취득 일자',
    SCR_RNK_NM   VARCHAR(5)                         COMMENT '점수등급명',
    REGISTER     VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE        DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    PRIMARY KEY (WRK_BSNS_SN, USER_SN, DTL_SN),
    CONSTRAINT fk_wrk_applcnt_lstcs_applcnt FOREIGN KEY (WRK_BSNS_SN, USER_SN) REFERENCES TN_WRK_APPLCNT (WRK_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청인어학';

-- 일자리신청인교육
CREATE TABLE IF NOT EXISTS TN_WRK_APPLCNT_EDC (
    WRK_BSNS_SN  BIGINT       NOT NULL              COMMENT '일자리사업순번',
    USER_SN      BIGINT       NOT NULL              COMMENT '사용자 순번',
    DTL_SN       INT          NOT NULL              COMMENT '상세순번',
    EDC_NM       VARCHAR(100)                       COMMENT '교육명',
    EDC_BEGIN_DE DATETIME                           COMMENT '교육시작일자',
    EDC_END_DE   DATETIME                           COMMENT '교육종료일자',
    EDC_INSTT_NM VARCHAR(50)                        COMMENT '교육기관명',
    EDC_CN       LONGTEXT                           COMMENT '교육내용(원본 CLOB)',
    REGISTER     VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE        DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    PRIMARY KEY (WRK_BSNS_SN, USER_SN, DTL_SN),
    CONSTRAINT fk_wrk_applcnt_edc_applcnt FOREIGN KEY (WRK_BSNS_SN, USER_SN) REFERENCES TN_WRK_APPLCNT (WRK_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청인교육';

-- 일자리신청인자격증
CREATE TABLE IF NOT EXISTS TN_WRK_APPLCNT_CRQFC (
    WRK_BSNS_SN      BIGINT       NOT NULL              COMMENT '일자리사업순번',
    USER_SN          BIGINT       NOT NULL              COMMENT '사용자순번',
    DTL_SN           INT          NOT NULL              COMMENT '상세순번',
    CRQFC_NM         VARCHAR(100)                       COMMENT '자격증명',
    ACQS_DE          DATETIME                           COMMENT '취득일자',
    PBLICTE_INSTT_NM VARCHAR(50)                        COMMENT '발행기관명',
    REGISTER         VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE            DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    PRIMARY KEY (WRK_BSNS_SN, USER_SN, DTL_SN),
    CONSTRAINT fk_wrk_applcnt_crqfc_applcnt FOREIGN KEY (WRK_BSNS_SN, USER_SN) REFERENCES TN_WRK_APPLCNT (WRK_BSNS_SN, USER_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청인자격증';

-- 채용공고
CREATE TABLE IF NOT EXISTS TN_EMPMN_PBLANC (
    PBLANC_SN             BIGINT       NOT NULL              COMMENT '공고 순번',
    USER_SN               BIGINT       NOT NULL              COMMENT '사용자순번',
    PBLANC_NM             VARCHAR(200) NOT NULL              COMMENT '공고 명',
    JSSFC_SE_CODE         VARCHAR(5)                         COMMENT '직종구분코드',
    WORK_STLE             VARCHAR(50)                        COMMENT '업무 형태',
    EMPLYM_STLE           VARCHAR(200)                       COMMENT '근무 형태',
    ACDMCR_SE_CODE        VARCHAR(5)                         COMMENT '학력 구분 코드',
    CAREER_SE_CODE        VARCHAR(5)                         COMMENT '경력구분코드',
    SALARY_CND_SE_CODE    VARCHAR(5)                         COMMENT '급여조건구분코드',
    RCEPT_BEGIN_DT        DATETIME                           COMMENT '접수시작일시',
    RCEPT_END_DT          DATETIME                           COMMENT '접수종료일시',
    HOPE_WORK_AREA        VARCHAR(5)                         COMMENT '희망 근무 지역',
    ZIP                   VARCHAR(7)                         COMMENT '우편번호',
    ADRES                 VARCHAR(100)                       COMMENT '주소',
    DTL_ADRES             VARCHAR(100)                       COMMENT '상세 주소',
    FILE_ID               BIGINT                             COMMENT '파일 ID',
    PRSNTN_PAPERS_NM      VARCHAR(200)                       COMMENT '제출서류명',
    WLFARE_SE_CODE        VARCHAR(5)                         COMMENT '복리후생구분코드',
    PVLTRT_MATTER_SE_CODE VARCHAR(5)                         COMMENT '우대사항구분코드',
    MHRHDC_SYSTEM_SE_CODE VARCHAR(5)                         COMMENT '모성보호제도구분코드',
    HR_CHARGER_SN         BIGINT                             COMMENT '담당자 순번',
    INFO_EXPSR_AT         VARCHAR(1)                         COMMENT '정보노출여부',
    PBLANC_CN             LONGTEXT                           COMMENT '공고 내용(원본 CLOB)',
    REGISTER              VARCHAR(20)  NOT NULL              COMMENT '등록자',
    RGSDE                 DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR                VARCHAR(20)  NOT NULL              COMMENT '수정자',
    UPDDE                 DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    RCRIT_NMPR            INT                                COMMENT '모집 인원',
    PICU_AGREE            VARCHAR(1)                         COMMENT '개인 정보 이용 동의',
    PITU_AGREE            VARCHAR(1)                         COMMENT '개인 정보 수집 동의',
    ORDTM_EMPMN_AT        VARCHAR(1)                         COMMENT '상시 채용 여부',
    INTRST_BSNS_CODE      VARCHAR(5)                         COMMENT '관심 사업 코드',
    PRIMARY KEY (PBLANC_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='채용공고';

-- 이력서 관리
CREATE TABLE IF NOT EXISTS TN_RESUME (
    RESUME_SN          BIGINT       NOT NULL              COMMENT '이력서순번',
    USER_SN            BIGINT                             COMMENT '사용자 순번',
    RESUME_SJ          VARCHAR(100)                       COMMENT '이력서 제목',
    LAST_DGRI_SE_CODE  VARCHAR(5)                         COMMENT '최종학위구분코드',
    HOPE_WORK_AREA     VARCHAR(5)                         COMMENT '희망 근무 지역',
    EMPLYM_TY_CODE     VARCHAR(5)                         COMMENT '고용 유형 코드',
    INFO_EXPSR_AT      VARCHAR(1)                         COMMENT '정보노출여부',
    BSNS_SE_CODE       VARCHAR(5)                         COMMENT '사업 구분 코드',
    REGISTER           VARCHAR(20)                        COMMENT '등록자',
    RGSDE              DATETIME     DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    UPDUSR             VARCHAR(20)                        COMMENT '수정자',
    UPDDE              DATETIME     DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    HOPE_SALARY        VARCHAR(5)                         COMMENT '희망 급여',
    EMPYMN_PVLTRT_CODE VARCHAR(5)                         COMMENT '취업 우대 코드',
    TROBL_CODE         VARCHAR(5)                         COMMENT '장애 코드',
    MTRSC_CODE         VARCHAR(5)                         COMMENT '병역 코드',
    JSSFC_SE_CODE      VARCHAR(5)                         COMMENT '직종구분코드',
    PRTFOLIO_FILE_ID   INT                                COMMENT '포트폴리오 파일 ID',
    CAREER_PD          INT                                COMMENT '경력 기간',
    PRIMARY KEY (RESUME_SN)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='이력서 관리';

-- (보류했던 FK 연결) 이력서 하위 테이블 → TN_RESUME
ALTER TABLE TN_RESUME_ACDMCR      ADD CONSTRAINT fk_resume_acdmcr_resume      FOREIGN KEY (RESUME_SN) REFERENCES TN_RESUME (RESUME_SN);
ALTER TABLE TN_RESUME_SELF_INTRCN ADD CONSTRAINT fk_resume_self_intrcn_resume FOREIGN KEY (RESUME_SN) REFERENCES TN_RESUME (RESUME_SN);
