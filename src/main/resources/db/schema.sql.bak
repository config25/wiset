    FEMALE_RGLLBR_CO          INT          DEFAULT 0             COMMENT '여성정규직수',
    ALL_IRGLLBR_CO            INT          DEFAULT 0             COMMENT '전체비정규직수',
    FEMALE_IRGLLBR_CO         INT          DEFAULT 0             COMMENT '여성비정규직수',
