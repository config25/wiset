    UPDUSR                    VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN, BIZRNO),
    CONSTRAINT fk_wrk_reqinst_crtrn_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관경력복귀';

-- 탈퇴
