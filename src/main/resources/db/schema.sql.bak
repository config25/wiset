    BEFFAT_DTY_EXPRNC_CN      TEXT                               COMMENT '사전직무경험내용(원본 VARCHAR2(4000))',
    LAST_DGRI_NM              VARCHAR(100)                       COMMENT '최종학위명',
    ANSLRY_AM                 BIGINT                             COMMENT '연봉금액',
    WORK_PRERNG_AREA_NM       VARCHAR(100)                       COMMENT '근무예정지역명',
    EMPLYM_TY_CODE            VARCHAR(5)                         COMMENT '고용유형코드',
    WORK_STLE_SE_CODE         VARCHAR(5)                         COMMENT '근무형태구분코드',
    WORK_STLE_ETC_NM          VARCHAR(50)                        COMMENT '근무형태기타명',
