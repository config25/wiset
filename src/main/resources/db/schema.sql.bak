    QLTTV_RSLT_CN           TEXT                               COMMENT '정성결과내용(원본 VARCHAR2(4000))',
    EMPLYM_STBLE_PLAN_CN    TEXT                               COMMENT '고용안정화계획내용(원본 VARCHAR2(4000))',
    EXPC_EFFECT_CN          TEXT                               COMMENT '기대효과내용(원본 VARCHAR2(4000))',
    RGSDE                     DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                  VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                     DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                    VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN, BIZRNO),
    CONSTRAINT fk_wrk_reqinst_replcjo_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관대체인력';

-- 일자리신청기관활용계획
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_PRCUSE_PLAN (
    WRK_BSNS_SN                 BIGINT       NOT NULL              COMMENT '일자리사업순번',
    BIZRNO                      VARCHAR(12)  NOT NULL              COMMENT '사업자번호',
