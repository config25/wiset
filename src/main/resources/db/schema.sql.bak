    PRCUSE_CRQFC_NM             VARCHAR(100)                       COMMENT '활용자격증명',
    PRCUSE_WLFARE_CN            TEXT                               COMMENT '활용복리후생내용(원본 VARCHAR2(4000))',
    SPORT_NEED_CN               TEXT                               COMMENT '지원필요내용(원본 VARCHAR2(4000))',
    PRCUSE_PLAN_CN              TEXT                               COMMENT '활용계획내용(원본 VARCHAR2(4000))',
    PRCUSE_PRERNG_USER_NM       VARCHAR(50)                        COMMENT '활용예정사용자명',
    PRCUSE_PRERNG_WORK_AREA_NM  VARCHAR(100)                       COMMENT '활용예정근무지역명',
    PRCUSE_BRTC_SE_CODE         VARCHAR(5)                         COMMENT '활용광역시도구분코드',
    PRCUSE_CAREER_BREAK_AT      VARCHAR(1)   DEFAULT 'N'           COMMENT '활용경력단절여부',
    PRCUSE_CAREER_BREAK_MONTH_CO INT                               COMMENT '활용경력단절개월수',
    PRCUSE_DTY_EXPRNC_PD_CODE   VARCHAR(5)                         COMMENT '활용직무경험기간코드',
    PRCUSE_ANSLRY_AM            BIGINT                             COMMENT '활용연봉금액',
    PRCUSE_MNTSLR_AM            BIGINT                             COMMENT '활용월급금액',
    PRCUSE_WORK_TIME_CO         INT                                COMMENT '활용근무시간수',
    MHRHDC_SYSTEM_SE_CODE       VARCHAR(5)                         COMMENT '모성보호제도구분코드',
    MHRHDC_SYSTEM_ETC_NM        VARCHAR(50)                        COMMENT '모성보호제도기타명',
    RGSDE                       DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                    VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                       DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                      VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN, BIZRNO),
    CONSTRAINT fk_wrk_reqinst_prcuse_plan_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관활용계획';

-- 일자리신청기관신진여성
CREATE TABLE IF NOT EXISTS TN_WRK_REQINST_NKW (
    WRK_BSNS_SN               BIGINT       NOT NULL              COMMENT '일자리사업순번',
    BIZRNO                    VARCHAR(12)  NOT NULL              COMMENT '사업자번호',
    RPRSNTV_SEXDSTN_SE_CODE   VARCHAR(5)                         COMMENT '대표자성별구분코드',
    RSRCH_HDCH_NM             VARCHAR(50)                        COMMENT '연구소장명',
    RSRCH_HDCH_SEXDSTN_SE_CODE VARCHAR(1)                        COMMENT '연구소장성별구분코드',
    FOND_DE                   DATETIME                           COMMENT '설립일자',
    BSNM_SE_CODE              VARCHAR(5)                         COMMENT '사업자구분코드',
    NWBSNS_AT                 VARCHAR(1)   DEFAULT 'N'           COMMENT '신사업여부',
    NWBSNS_INDUST_RLM_TY_CODE VARCHAR(5)                         COMMENT '신사업산업분야유형코드',
    ORDTM_LABRR_CO            INT          DEFAULT 0             COMMENT '상시근로자수',
    ALL_RSRCH_LABRR_CO        INT          DEFAULT 0             COMMENT '전체연구근로자 수',
    FEMALE_RSRCH_LABRR_CO     INT          DEFAULT 0             COMMENT '여성연구근로자 수',
    FEMALE_RSRCH_LABRR_PT     DECIMAL(6,2) DEFAULT 0             COMMENT '여성연구근로자백분율',
    ALL_RGLLBR_CO             INT          DEFAULT 0             COMMENT '전체정규직수',
    FEMALE_RGLLBR_CO          INT          DEFAULT 0             COMMENT '여성정규직수',
    FEMALE_RGLLBR_PT          DECIMAL(6,2) DEFAULT 0             COMMENT '여성정규직백분율',
    ALL_IRGLLBR_CO            INT          DEFAULT 0             COMMENT '전체비정규직수',
    FEMALE_IRGLLBR_PT         DECIMAL(6,2) DEFAULT 0             COMMENT '여성비정규직백분율',
    FEMALE_IRGLLBR_CO         INT          DEFAULT 0             COMMENT '여성비정규직수',
    DTY_RLM_NM                VARCHAR(50)                        COMMENT '직무분야명',
    MAJOR_NM                  VARCHAR(50)                        COMMENT '전공명',
    LAST_DGRI_NM              VARCHAR(100)                       COMMENT '최종학위명',
    ANSLRY_AM                 BIGINT                             COMMENT '연봉금액',
    WORK_PRERNG_AREA_NM       VARCHAR(100)                       COMMENT '근무예정지역명',
    EMPLYM_TY_CODE            VARCHAR(5)                         COMMENT '고용유형코드',
    INSTLM_ZIP                VARCHAR(7)                         COMMENT '연구소우편번호',
    INSTLM_ADRES              VARCHAR(100)                       COMMENT '연구소주소',
    INSTLM_DTL_ADRES          VARCHAR(50)                        COMMENT '연구소상세주소',
    WORKPC_ZIP                VARCHAR(7)                         COMMENT '근무지우편번호',
    WORKPC_ADRES              VARCHAR(100)                       COMMENT '근무지주소',
    WORKPC_DTL_ADRES          VARCHAR(50)                        COMMENT '근무지상세주소',
    RSRCH_RLM_CN              TEXT                               COMMENT '연구분야내용(원본 VARCHAR2(4000))',
    RSRCH_RSLT_CN             TEXT                               COMMENT '연구결과내용(원본 VARCHAR2(4000))',
    FDQNT_RSLT_CN             TEXT                               COMMENT '정량결과내용(원본 VARCHAR2(4000))',
    QLTTV_RSLT_CN             TEXT                               COMMENT '정성결과내용(원본 VARCHAR2(4000))',
    EXPC_EFFECT_CN            TEXT                               COMMENT '기대효과내용(원본 VARCHAR2(4000))',
    RGSDE                     DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '등록일',
    REGISTER                  VARCHAR(20)  NOT NULL              COMMENT '등록자',
    UPDDE                     DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '수정일',
    UPDUSR                    VARCHAR(20)  NOT NULL              COMMENT '수정자',
    PRIMARY KEY (WRK_BSNS_SN, BIZRNO),
    CONSTRAINT fk_wrk_reqinst_nkw_reqinst FOREIGN KEY (WRK_BSNS_SN, BIZRNO) REFERENCES TN_WRK_REQINST (WRK_BSNS_SN, BIZRNO)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='일자리신청기관신진여성';

-- 일자리신청기관경력복귀
